---
import { Icon } from "astro-icon/components";
import PageLayout from "@/layouts/Base.astro";
---

<PageLayout
  meta={{
    title: "NeoStation - Modern Retro Gaming Frontend",
    ogImage: "/screenshots/neostation-01.webp",
  }}
>
  <!-- Hero Section -->
  <div class="hero py-16 md:py-24">
    <div class="hero-content text-center max-w-3xl">
      <div class="space-y-8">
        <h1 class="text-4xl md:text-6xl font-bold tracking-tight">
          The <span class="text-primary">Multiplatform</span> Frontend.
        </h1>
        <p class="text-lg md:text-xl text-base-content/60 max-w-2xl mx-auto leading-relaxed">
          A unified gaming experience for Windows, Android, macOS, and Linux.
          Beautiful UI, automatic metadata scraping, achievement tracking and
          cross-device save sync.
        </p>
        <div class="flex flex-wrap justify-center gap-4 pt-4">
          <a href="/downloads/" class="btn btn-primary btn-lg">
            Get Started
            <Icon name="heroicons:arrow-right" class="w-5 h-5" />
          </a>
          <a href="/guide/" class="btn btn-ghost btn-lg">
            User Guide
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Features Grid -->
  <section class="mb-20">
    <h2 class="text-3xl md:text-4xl font-bold text-primary tracking-tight mb-12 text-center">
      Why NeoStation?
    </h2>

    <div class="grid md:grid-cols-3 gap-6">
      <!-- Card 1 -->
      <div class="card card-border bg-base-200 transition-all duration-500 group">
        <figure class="overflow-hidden aspect-video">
          <img src="/home/stunning.webp" alt="Stunning UI" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
        </figure>
        <div class="card-body">
          <div class="flex items-center gap-3 mb-2">
            <div class="size-10 rounded-xl bg-primary/10 flex items-center justify-center">
              <Icon name="heroicons:paint-brush" class="w-5 h-5 text-primary" />
            </div>
            <h3 class="card-title">Stunning UI</h3>
          </div>
          <p class="text-base-content/60 text-sm">Forget boring lists. Browsing your library should be as fun as playing it. Experience rich visuals and smooth animations designed for the modern era.</p>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="card card-border bg-base-200 transition-all duration-500 group">
        <figure class="overflow-hidden aspect-video">
          <img src="/home/neosync.webp" alt="Cloud Sync" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
        </figure>
        <div class="card-body">
          <div class="flex items-center gap-3 mb-2">
            <div class="size-10 rounded-xl bg-info/10 flex items-center justify-center">
              <Icon name="heroicons:cloud-arrow-up" class="w-5 h-5 text-info" />
            </div>
            <h3 class="card-title">Cloud Sync</h3>
          </div>
          <p class="text-base-content/60 text-sm">Sync your saves across devices effortlessly. Connect your preferred sync provider. Start on your PC, pick up on your handheld.</p>
        </div>
      </div>

      <!-- Card 3 -->
      <div class="card card-border bg-base-200 transition-all duration-500 group">
        <figure class="overflow-hidden aspect-video">
          <img src="/home/plug-and-play.webp" alt="Plug & Play" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
        </figure>
        <div class="card-body">
          <div class="flex items-center gap-3 mb-2">
            <div class="size-10 rounded-xl bg-warning/10 flex items-center justify-center">
              <Icon name="heroicons:rocket-launch" class="w-5 h-5 text-warning" />
            </div>
            <h3 class="card-title">Plug & Play</h3>
          </div>
          <p class="text-base-content/60 text-sm">No complex configuration files. Intelligent scanning detects your games automatically so you can spend your time playing, not tweaking.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Support Section -->
  <section class="mb-20">
    <div class="card bg-base-200">
      <div class="card-body">
        <div class="flex flex-col lg:flex-row items-center justify-between gap-12">
          <div class="text-center lg:text-left space-y-6 max-w-2xl">
            <h2 class="text-3xl md:text-5xl font-bold tracking-tight">
              Support <span class="text-primary">NeoStation.</span>
            </h2>
            <p class="text-base-content/60 text-lg leading-relaxed">
              NeoStation is a labor of love and remains free for everyone. Your
              support helps me cover infrastructure costs and allows me to
              dedicate more time to improving the project.
            </p>
          </div>

          <div class="flex flex-col sm:flex-row gap-4 w-full lg:w-auto">
            <a
              href="https://ko-fi.com/neostation"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-lg"
              style="background-color:#29ABE2; color:#fff; border-color:#29ABE2;"
            >
              <Icon name="simple-icons:kofi" class="w-5 h-5" />
              Support on Ko-fi
            </a>
            <a
              href="https://www.patreon.com/cw/NeoStation"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-lg"
              style="background-color:#FF424D; color:#fff; border-color:#FF424D;"
            >
              <Icon name="simple-icons:patreon" class="w-5 h-5" />
              Become a Patron
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<!-- Image Modal -->
<div
  id="imageModal"
  class="fixed inset-0 bg-black/75 hidden z-50 flex items-center justify-center p-4"
  onclick="closeModal()"
>
  <div class="relative max-w-4xl max-h-full">
    <img
      id="modalImage"
      src=""
      alt="NeoStation Screenshot"
      class="rounded-xl max-w-full max-h-full object-contain"
    />
    <button
      onclick="closeModal()"
      class="absolute top-4 right-4 text-white text-2xl font-bold hover:text-base-content/80 transition-colors"
    >
      ×
    </button>
  </div>
</div>

<script>
  function openModal(imageSrc: string) {
    const modal = document.getElementById("imageModal");
    const modalImage = document.getElementById("modalImage") as HTMLImageElement | null;
    if (modal && modalImage) {
      modalImage.src = imageSrc;
      modal.classList.remove("hidden");
      document.body.style.overflow = "hidden";
    }
  }

  function closeModal() {
    const modal = document.getElementById("imageModal");
    if (modal) {
      modal.classList.add("hidden");
      document.body.style.overflow = "auto";
    }
  }

  function initModal() {
    const modalTriggers = document.querySelectorAll(".modal-trigger");
    modalTriggers.forEach((img) => {
      (img as HTMLElement).addEventListener("click", () => {
        const imageSrc = img.getAttribute("data-image");
        if (imageSrc) openModal(imageSrc);
      });
    });

    const modal = document.getElementById("imageModal");
    if (modal) {
      modal.addEventListener("click", (e) => {
        if (e.target === modal) closeModal();
      });
    }

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeModal();
    });
  }

  document.addEventListener("astro:page-load", initModal);
</script>
