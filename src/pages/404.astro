---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	description: "Oops! It looks like this page is lost in space!",
	title: "404 • Page Not Found",
};
---

<PageLayout meta={meta}>
  <div class="hero min-h-[60vh]">
    <div class="hero-content text-center">
      <div class="max-w-md">
        <div class="mb-8">
          <span class="text-[10rem] font-black leading-none text-base-content/10 select-none">404</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-black text-base-content tracking-tight mb-4">
          Page Not <span class="text-primary">Found</span>
        </h1>
        <p class="text-base-content/60 text-lg mb-10 leading-relaxed">
          The page you're looking for doesn't exist or has been moved. Let's get you back on track.
        </p>
        <a href="/" class="btn btn-primary btn-lg">
          ← Back to Home
        </a>
      </div>
    </div>
  </div>
</PageLayout>
