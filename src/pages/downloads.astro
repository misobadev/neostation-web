---
import PageLayout from "@/layouts/Base.astro";
import { Icon } from "astro-icon/components";
import type { SiteMeta } from "@/types";

const meta: SiteMeta = {
  description:
    "Download NeoStation for Windows, Android, Linux, and macOS. Experience the ultimate retro gaming frontend with exceptional UI/UX and seamless performance.",
  ogImage: "/ogImageBig.png",
  title: "Get NeoStation - The Future of Retro Gaming",
  twitterCard: "summary",
  twitterImage: "/ogImageSmall.png",
};

const latestVersion = "Beta 0.7.4+89";
const releaseDate = "May 01, 2026";
const releaseUrl =
  "https://github.com/misobadev/neostation-frontend/releases/latest";

const windowsLink =
  "https://github.com/misobadev/neostation-frontend/releases/download/v0.7.4+89/neostation-windows-x64-0.7.4+89.zip";
const androidApkLink =
  "https://github.com/misobadev/neostation-frontend/releases/download/v0.7.4+89/neostation-android-arm64-v8a-0.7.4+89.apk";
const linuxX64Link =
  "https://github.com/misobadev/neostation-frontend/releases/download/v0.7.4+89/neostation-linux-x86_64-0.7.4+89.AppImage";
const linuxArm64Link =
  "https://github.com/misobadev/neostation-frontend/releases/download/v0.7.4+89/neostation-linux-arm64-0.7.4+89.AppImage";
const macosLink =
  "https://github.com/misobadev/neostation-frontend/releases/download/v0.7.4+89/neostation-macos-universal-0.7.4+89.dmg";

const platforms = [
  {
    name: "Windows",
    version: latestVersion,
    icon: "heroicons:computer-desktop",
    color: "text-info",
    bgColor: "bg-info/10",
    borderColor: "hover:border-info/50",
    shadowColor: "hover:shadow-info/10",
    requirements: "Windows 10 / 11 (64-bit)",
    link: windowsLink,
    label: "Download for Windows",
    dataKey: "windows",
    note: "Requires <a href='https://aka.ms/vs/17/release/vc_redist.x64.exe' target='_blank' class='underline hover:text-base-content/70 transition-colors'>Microsoft Visual C++ Redistributable (x64)</a>.",
  },
  {
    name: "Android",
    version: latestVersion,
    icon: "heroicons:device-phone-mobile",
    color: "text-success",
    bgColor: "bg-success/10",
    borderColor: "hover:border-success/50",
    shadowColor: "hover:shadow-success/10",
    requirements: "7.0+ (API 24+)",
    isAndroid: true,
    note: "Requires 'All Files Access' permission on Android 11+ to manage games and saves.",
    links: [
      {
        label: "Download APK",
        url: androidApkLink,
        primary: true,
        recommended: false,
        dataKey: "android-apk",
      },
      {
        label: "Get it on Obtainium",
        url: "https://apps.obtainium.imranr.dev/redirect?r=obtainium://app/%7B%22id%22%3A%22com.neogamelab.neostation%22%2C%22url%22%3A%22https%3A%2F%2Fgithub.com%2Fmisobadev%2Fneostation-frontend%22%2C%22author%22%3A%22NeoGameLab%22%2C%22name%22%3A%22NeoStation%22%2C%22preferredApkIndex%22%3A0%2C%22additionalSettings%22%3A%22%7B%5C%22includePrereleases%5C%22%3Afalse%2C%5C%22fallbackToOlderReleases%5C%22%3Atrue%2C%5C%22filterReleaseTitlesByRegEx%5C%22%3A%5C%22%5C%22%2C%5C%22filterReleaseNotesByRegEx%5C%22%3A%5C%22%5C%22%2C%5C%22verifyLatestTag%5C%22%3Afalse%2C%5C%22sortMethodChoice%5C%22%3A%5C%22date%5C%22%2C%5C%22useLatestAssetDateAsReleaseDate%5C%22%3Afalse%2C%5C%22releaseTitleAsVersion%5C%22%3Afalse%2C%5C%22trackOnly%5C%22%3Afalse%2C%5C%22includePrereleases%5C%22%3Afalse%2C%5C%22fallbackToOlderReleases%5C%22%3Atrue%2C%5C%22filterReleaseTitlesByRegEx%5C%22%3A%5C%22%5C%22%2C%5C%22filterReleaseNotesByRegEx%5C%22%3A%5C%22%5C%22%2C%5C%22verifyLatestTag%5C%22%3Afalse%2C%5C%22sortMethodChoice%5C%22%3A%5C%22date%5C%22%2C%5C%22useLatestAssetDateAsReleaseDate%5C%22%3Afalse%2C%5C%22releaseTitleAsVersion%5C%22%3Afalse%2C%5C%22trackOnly%5C%22%3Afalse%2C%5C%22versionExtractionRegEx%5C%22%3A%5C%22%5C%22%2C%5C%22matchGroupToUse%5C%22%3A%5C%22%5C%22%2C%5C%22versionDetection%5C%22%3Atrue%2C%5C%22releaseDateAsVersion%5C%22%3Afalse%2C%5C%22useVersionCodeAsOSVersion%5C%22%3Afalse%2C%5C%22apkFilterRegEx%5C%22%3A%5C%22%5C%22%2C%5C%22invertAPKFilter%5C%22%3Atrue%2C%5C%22autoApkFilterByArch%5C%22%3Atrue%2C%5C%22appName%5C%22%3A%5C%22%5C%22%2C%5C%22appAuthor%5C%22%3A%5C%22%5C%22%2C%5C%22shizukuPretendToBeGooglePlay%5C%22%3Afalse%2C%5C%22allowInsecure%5C%22%3Afalse%2C%5C%22exemptFromBackgroundUpdates%5C%22%3Afalse%2C%5C%22skipUpdateNotifications%5C%22%3Afalse%2C%5C%22about%5C%22%3A%5C%22%5C%22%2C%5C%22refreshBeforeDownload%5C%22%3Afalse%2C%5C%22includeZips%5C%22%3Afalse%2C%5C%22zippedApkFilterRegEx%5C%22%3A%5C%22%5C%22%7D%22%2C%22overrideSource%22%3Anull%7D",
        primary: false,
        recommended: false,
      },
    ],
  },
  {
    name: "Linux",
    version: latestVersion,
    icon: "heroicons:command-line",
    color: "text-warning",
    bgColor: "bg-warning/10",
    borderColor: "hover:border-warning/50",
    shadowColor: "hover:shadow-warning/10",
    requirements: "AppImage (x86_64 / ARM64)",
    isLinux: true,
    links: [
      {
        label: "Download for Linux (x64)",
        url: linuxX64Link,
        primary: true,
        recommended: false,
        dataKey: "linux-x64",
      },
      {
        label: "Download for Linux (ARM64)",
        url: linuxArm64Link,
        primary: false,
        recommended: false,
        dataKey: "linux-arm64",
      },
    ],
  },
  {
    name: "macOS",
    version: latestVersion,
    icon: "simple-icons:apple",
    color: "text-secondary",
    bgColor: "bg-secondary/10",
    borderColor: "hover:border-secondary/50",
    shadowColor: "hover:shadow-secondary/10",
    requirements: "Universal (Intel & Apple Silicon)",
    link: macosLink,
    label: "Download for macOS",
    dataKey: "macos",
    note: "If blocked by system, go to System Settings > Privacy & Security and click 'Open Anyway'.",
  },
];

const systemRequirements = [
  {
    platform: "Android",
    icon: "heroicons:device-phone-mobile",
    minCpu: "Cortex-A53 / A55 @ 1.5 GHz",
    cores: "4 Cores",
    minRam: "2 GB",
    recRam: "3–4 GB",
    minGpu: "Mali-G31 / Adreno 3xx",
    notes:
      "With 1 GB, the OS leaves ~400 MB free; the app requires more for stable performance.",
  },
  {
    platform: "Linux ARM64",
    icon: "heroicons:command-line",
    minCpu: "Cortex-A53 / A55 @ 1.5 GHz",
    cores: "4 Cores",
    minRam: "1.5 GB",
    recRam: "2 GB",
    minGpu: "GLES 3.0 / Vulkan",
    notes:
      "More viable than Android on 1 GB devices due to lower OS overhead.",
  },
  {
    platform: "Linux x64",
    icon: "heroicons:command-line",
    minCpu: "Intel Haswell / AMD Excavator",
    cores: "2 Cores",
    minRam: "2 GB",
    recRam: "4 GB",
    minGpu: "OpenGL 3.0+",
  },
  {
    platform: "macOS",
    icon: "simple-icons:apple",
    minCpu: "Intel i5 4th Gen / Apple M1",
    cores: "4 Cores",
    minRam: "4 GB",
    recRam: "8 GB",
    minGpu: "Integrated Intel / Apple Silicon",
    notes: "Rosetta translation increases resource consumption on Intel Macs.",
  },
  {
    platform: "Windows",
    icon: "heroicons:computer-desktop",
    minCpu: "Intel i3 4th Gen / AMD FX",
    cores: "2 Cores",
    minRam: "4 GB",
    recRam: "8 GB",
    minGpu: "DirectX 11",
    notes: "Windows 10/11 typically consumes 2–3 GB of RAM on its own.",
  },
];
---

<PageLayout meta={meta}>
  <div class="py-12 md:py-20">

    <div class="max-w-7xl mx-auto px-4">
      <!-- Hero -->
      <div class="text-center mb-16">
        <h1
          class="text-4xl md:text-6xl font-bold text-base-content mb-6 tracking-tight"
        >
          Get <span class="text-primary">NeoStation</span>
        </h1>
        <div class="max-w-3xl mx-auto">
          <p class="text-lg md:text-xl text-base-content/60 leading-relaxed mb-8">
            Experience the future of retro gaming on your favorite device.
            Select your platform below to download the latest stable beta.
          </p>

          <a
            href={releaseUrl}
            target="_blank"
            data-release-badge
            class="inline-flex items-center gap-4 px-6 py-3 bg-base-200 rounded-2xl border border-base-content/10 shadow-xl transition-colors hover:border-base-content/20"
          >
            <div
              class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center"
            >
              <Icon name="heroicons:rocket-launch" class="w-6 h-6 text-primary" />
            </div>
            <div class="text-left">
              <div
                class="text-xs font-bold text-base-content/50 uppercase tracking-widest"
              >
                Latest Stable
              </div>
              <div class="text-lg font-bold text-base-content">
                <span data-release-version>{latestVersion}</span>
                <span data-release-date class="text-base-content/40 text-sm font-normal ml-2"
                  >, {releaseDate}</span
                >
              </div>
            </div>
          </a>
        </div>
      </div>

      <!-- Platform Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-24">
        {platforms.map(p => (
          <div class="card card-border bg-base-200 hover:border-primary/50 transition-all duration-300">
            <div class="card-body">
              <div class="size-14 rounded-2xl bg-primary/10 flex items-center justify-center mb-4">
                <Icon name={p.icon} class="w-8 h-8 text-primary" />
              </div>
              <h3 class="card-title">{p.name}</h3>
              <p class="text-xs text-base-content/50 font-medium uppercase tracking-wider">{p.requirements}</p>
              <div class="mt-auto space-y-2">
                {p.isAndroid || p.isLinux ? (
                  p.links.map(l => (
                    <a href={l.url} target="_blank" data-download={l.dataKey} class={`btn btn-block btn-sm relative overflow-hidden ${l.primary ? "btn-primary" : "btn-ghost"}`}>
                      {l.recommended && <span class="badge badge-warning badge-xs absolute top-0 right-0">Best</span>}
                      {l.label}
                    </a>
                  ))
                ) : (
                  <a href={p.link} target="_blank" data-download={p.dataKey} class="btn btn-primary btn-block">{p.label}</a>
                )}
              </div>
              {p.note && <p class="text-[10px] text-base-content/40 italic mt-2"><span set:html={p.note} /></p>}
            </div>
          </div>
        ))}
      </div>

      <!-- System Requirements -->
      <div class="mb-24">
        <div class="flex items-center gap-3 mb-8">
          <div
            class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center"
          >
            <Icon name="heroicons:bolt" class="w-6 h-6 text-primary" />
          </div>
          <h2 class="text-3xl font-bold text-base-content">System Requirements</h2>
        </div>

        <div class="overflow-x-auto rounded-box border border-base-content/10">
          <table class="table">
            <thead>
              <tr class="text-base-content/50 text-xs uppercase tracking-wider">
                <th>Platform</th><th>Min CPU</th><th>Cores</th><th>Min RAM</th><th>Recommended</th><th>Min GPU</th>
              </tr>
            </thead>
            <tbody>
              {systemRequirements.map(req => (
                <>
                  <tr class="hover:bg-base-content/[0.02]">
                    <td class="flex items-center gap-2 font-bold"><Icon name={req.icon} class="w-5 h-5 text-base-content/50" />{req.platform}</td>
                    <td class="text-sm">{req.minCpu}</td>
                    <td class="text-sm">{req.cores}</td>
                    <td class="text-sm">{req.minRam}</td>
                    <td><span class="badge badge-primary badge-sm">{req.recRam}</span></td>
                    <td class="text-sm">{req.minGpu}</td>
                  </tr>
                  {req.notes && (
                    <tr class="bg-base-content/[0.02]">
                      <td colspan="6" class="text-[11px] text-base-content/50 italic px-4 py-2">
                        <span class="text-warning/70 mr-1 font-bold">*</span> {req.notes}
                      </td>
                    </tr>
                  )}
                </>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Beta Section & Discord -->
      <div class="grid md:grid-cols-2 gap-6 mb-24">
        <div class="alert alert-warning shadow-lg">
          <div class="flex items-start gap-4">
            <Icon name="heroicons:sparkles" class="w-6 h-6 shrink-0" />
            <div>
              <h3 class="font-bold">Beta Software Notice</h3>
              <p class="text-sm">These are Beta releases intended for testing and feedback. While stable, you may encounter minor bugs. Join the community to report issues and help improve the experience.</p>
              <div class="flex items-center gap-2 text-xs mt-2"><span class="w-2 h-2 rounded-full bg-warning animate-pulse"></span>ACTIVE DEVELOPMENT</div>
            </div>
          </div>
        </div>
        <div class="alert shadow-lg">
          <div class="flex items-start gap-4">
            <Icon name="simple-icons:discord" class="w-6 h-6 text-secondary shrink-0" />
            <div>
              <h3 class="font-bold text-base-content">Join the Discussion</h3>
              <p class="text-sm text-base-content/60">Get help, share themes, report bugs, and stay updated on the latest releases.</p>
              <div class="flex gap-2 mt-3">
                <a href="https://discord.gg/xE2kgKsRVq" class="btn btn-secondary btn-sm">Discord</a>
                <a href="https://github.com/misobadev/neostation-frontend/discussions" class="btn btn-ghost btn-sm">GitHub Discussions</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const API_URL = "https://api.github.com/repos/misobadev/neostation-frontend/releases/latest";

    async function loadLatestRelease() {
      try {
        const res = await fetch(API_URL, {
          headers: { Accept: "application/vnd.github+json" },
        });
        if (!res.ok) return;
        const data = await res.json();

        const badge = document.querySelector("[data-release-badge]") as HTMLAnchorElement | null;
        if (badge) {
          badge.href = data.html_url || badge.href;
          const versionEl = badge.querySelector("[data-release-version]");
          const dateEl = badge.querySelector("[data-release-date]");
          if (versionEl) {
            versionEl.textContent = data.name
              ? data.name.replace(/^NeoStation\s+/i, "")
              : data.tag_name?.replace(/^v/, "Beta ");
          }
          if (dateEl && data.published_at) {
            const d = new Date(data.published_at);
            dateEl.textContent =
              ", " +
              d.toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              });
          }
        }

        for (const asset of data.assets || []) {
          const name = asset.name;
          const url = asset.browser_download_url;
          let key = null;

          if (name.includes("windows") && name.endsWith(".zip")) key = "windows";
          else if (name.includes("android") && name.endsWith(".apk")) key = "android-apk";
          else if (name.includes("linux") && name.includes("x86_64") && name.endsWith(".AppImage")) key = "linux-x64";
          else if (name.includes("linux") && name.includes("arm64") && name.endsWith(".AppImage")) key = "linux-arm64";
          else if (name.includes("macos") && name.endsWith(".dmg")) key = "macos";

          if (key) {
            const link = document.querySelector(`[data-download="${key}"]`) as HTMLAnchorElement | null;
            if (link) link.href = url;
          }
        }
      } catch (e) {
        console.error("Failed to fetch latest GitHub release:", e);
      }
    }

    loadLatestRelease();
  </script>
</PageLayout>
