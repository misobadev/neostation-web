---
import { Icon } from "astro-icon/components";
import PageLayout from "@/layouts/Base.astro";

const meta = {
  description:
    "NeoStation - Modern multi-platform retro gaming frontend with RetroAchievements, ScreenScraper, and cross-platform compatibility.",
  title: "What is NeoStation? - NeoStation",
  ogImage: "/screenshots/neostation-01.webp",
};

const pillars = [
  {
    title: "Multi-Platform",
    icon: "heroicons:computer-desktop",
    color: "text-primary",
    description:
      "One frontend, every device. Windows, Android, Linux, and macOS share the same interface, library, and experience. Start on your PC, pick up on your handheld.",
  },
  {
    title: "RetroAchievements",
    icon: "heroicons:trophy",
    color: "text-warning",
    description:
      "Built-in RetroAchievements integration. Track your unlocked achievements, view progress, and compete on leaderboards directly from the frontend, no extra setup.",
  },
  {
    title: "ScreenScraper",
    icon: "heroicons:magnifying-glass-circle",
    color: "text-info",
    description:
      "Automatic metadata and artwork scraping via ScreenScraper. Box art, descriptions, release dates, and ratings, your library looks exactly how it should.",
  },
];

const platforms = [
  { name: "Windows", icon: "heroicons:computer-desktop", color: "text-info", note: "10 / 11 (64-bit)" },
  { name: "Android", icon: "heroicons:device-phone-mobile", color: "text-success", note: "7.0+ (API 24+)" },
  { name: "Linux", icon: "heroicons:command-line", color: "text-warning", note: "AppImage (x64 / ARM64)" },
  { name: "macOS", icon: "simple-icons:apple", color: "text-secondary", note: "Intel & Apple Silicon" },
];
---

<PageLayout meta={meta}>
  <div class="py-12 md:py-20">
    <div class="max-w-7xl mx-auto px-4">
      <!-- Hero -->
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-6xl font-bold text-base-content mb-6 tracking-tight">
          What is <span class="text-primary">NeoStation?</span>
        </h1>
        <div class="max-w-3xl mx-auto">
          <p class="text-lg md:text-xl text-base-content/60 leading-relaxed">
            A modern, open source retro gaming frontend built for
            <span class="text-base-content font-semibold italic">every platform</span>.
            Beautiful UI, automatic metadata, achievement tracking, everything
            your collection deserves.
          </p>
        </div>
      </div>

      <!-- Screenshot Slider -->
      <div class="relative max-w-5xl mx-auto mb-24">
        <div
          class="relative w-full aspect-video rounded-3xl overflow-hidden shadow-2xl border border-base-content/20 z-10 bg-base-200"
          id="hero-slider"
        >
          {
            [1, 2, 3, 4].map((num, index) => (
              <img
                src={`/screenshots/neostation-0${num}.webp`}
                alt={`NeoStation Interface ${num}`}
                class={`absolute inset-0 w-full h-full object-cover transition-opacity duration-1000 ${index === 0 ? "opacity-100" : "opacity-0"}`}
                data-index={index}
              />
            ))
          }
        </div>
      </div>

      <!-- Core Pillars -->
      <div class="grid md:grid-cols-3 gap-6 mb-24">
        {pillars.map(pillar => (
          <div class="card card-border bg-base-200">
            <div class="card-body">
              <div class="size-12 rounded-2xl bg-primary/10 flex items-center justify-center mb-4">
                <Icon name={pillar.icon} class={`w-6 h-6 ${pillar.color}`} />
              </div>
              <h3 class="card-title">{pillar.title}</h3>
              <p class="text-base-content/60 text-sm">{pillar.description}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Multi-Platform Section -->
      <div class="grid lg:grid-cols-2 gap-12 mb-24 items-center">
        <div class="space-y-8">
          <div>
            <h2 class="text-3xl font-bold text-base-content mb-6 border-l-4 border-primary pl-6 italic">
              One App. Every Device.
            </h2>
            <p class="text-base-content/60 leading-relaxed mb-6">
              NeoStation runs natively on Windows, Android, Linux, and macOS
              with a landscape-optimized interface designed for both desktop
              monitors and handheld screens. Your library, settings, and
              experience stay consistent across every device you own.
            </p>
            <p class="text-base-content/60 leading-relaxed">
              Android TV and Google TV are also supported, including a built-in
              file explorer for devices that lack a native file picker.
            </p>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div class="stat bg-base-200 border border-base-content/10 rounded-2xl">
              <div class="stat-value text-primary">100+</div>
              <div class="stat-desc text-xs uppercase font-bold tracking-wider">Systems Supported</div>
            </div>
            <div class="stat bg-base-200 border border-base-content/10 rounded-2xl">
              <div class="stat-value text-info">4</div>
              <div class="stat-desc text-xs uppercase font-bold tracking-wider">Native Platforms</div>
            </div>
          </div>
        </div>

        <!-- Platform Cards -->
        <div class="grid grid-cols-2 gap-4">
          {
            platforms.map((p) => (
              <div class="card card-border bg-base-200">
                <div class="card-body flex-row items-center gap-4 p-5">
                  <div class="w-10 h-10 rounded-xl bg-base-content/5 flex items-center justify-center shrink-0">
                    <Icon name={p.icon} class={`w-6 h-6 ${p.color}`} />
                  </div>
                  <div>
                    <div class="card-title text-sm">{p.name}</div>
                    <div class="text-base-content/50 text-xs">{p.note}</div>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Integrations Section -->
      <div class="mb-24">
        <div class="flex items-center gap-4 mb-12">
          <h2 class="text-3xl font-bold text-base-content pl-6 border-l-4 border-warning">
            Integrations
          </h2>
          <div class="divider flex-grow"></div>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          <!-- RetroAchievements -->
          <div class="card bg-base-200 border border-base-content/10">
            <div class="card-body">
              <div class="flex items-center gap-4 mb-6">
                <div class="w-12 h-12 rounded-2xl bg-warning/10 flex items-center justify-center shrink-0">
                  <Icon name="heroicons:trophy" class="w-7 h-7 text-warning" />
                </div>
                <div>
                  <h3 class="card-title">RetroAchievements</h3>
                  <a href="https://retroachievements.org" target="_blank" class="text-xs text-base-content/50 hover:text-warning transition-colors">retroachievements.org ↗</a>
                </div>
              </div>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <Icon name="heroicons:check-circle" class="w-4 h-4 text-warning mt-0.5 shrink-0" />
                  <span class="text-sm text-base-content/60">Login with your RetroAchievements account directly in the app.</span>
                </li>
                <li class="flex items-start gap-3">
                  <Icon name="heroicons:check-circle" class="w-4 h-4 text-warning mt-0.5 shrink-0" />
                  <span class="text-sm text-base-content/60">View per-game achievement progress and unlocks at a glance.</span>
                </li>
                <li class="flex items-start gap-3">
                  <Icon name="heroicons:check-circle" class="w-4 h-4 text-warning mt-0.5 shrink-0" />
                  <span class="text-sm text-base-content/60">Systems incompatible with RA are automatically hidden from RA UI elements.</span>
                </li>
              </ul>
            </div>
          </div>

          <!-- ScreenScraper -->
          <div class="card bg-base-200 border border-base-content/10">
            <div class="card-body">
              <div class="flex items-center gap-4 mb-6">
                <div class="w-12 h-12 rounded-2xl bg-info/10 flex items-center justify-center shrink-0">
                  <Icon name="heroicons:magnifying-glass-circle" class="w-7 h-7 text-info" />
                </div>
                <div>
                  <h3 class="card-title">ScreenScraper</h3>
                  <a href="https://www.screenscraper.fr" target="_blank" class="text-xs text-base-content/50 hover:text-info transition-colors">screenscraper.fr ↗</a>
                </div>
              </div>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <Icon name="heroicons:check-circle" class="w-4 h-4 text-info mt-0.5 shrink-0" />
                  <span class="text-sm text-base-content/60">Scrape box art, screenshots, descriptions, and release dates automatically.</span>
                </li>
                <li class="flex items-start gap-3">
                  <Icon name="heroicons:check-circle" class="w-4 h-4 text-info mt-0.5 shrink-0" />
                  <span class="text-sm text-base-content/60">Batch scrape entire libraries or scrape individual games on demand.</span>
                </li>
                <li class="flex items-start gap-3">
                  <Icon name="heroicons:check-circle" class="w-4 h-4 text-info mt-0.5 shrink-0" />
                  <span class="text-sm text-base-content/60">Real game names from ScreenScraper can replace raw ROM filenames in the UI.</span>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <!-- Gallery -->
      <div class="mb-24">
        <div class="flex items-center justify-between mb-12">
          <h2 class="text-3xl font-bold text-base-content pl-6 border-l-4 border-primary">
            Visual Journey
          </h2>
          <div class="hidden md:block h-[1px] flex-grow mx-8 bg-base-content/5"></div>
        </div>

        <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
          {
            [1, 2, 3, 4, 5, 6, 7, 8].map((num) => (
              <div
                class="card card-border bg-base-200 group relative aspect-video overflow-hidden cursor-pointer modal-trigger"
                data-image={`/screenshots/neostation-0${num}.webp`}
              >
                <img
                  src={`/screenshots/neostation-0${num}.webp`}
                  alt={`NeoStation Screenshot ${num}`}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 opacity-70 group-hover:opacity-100"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
                  <span class="text-white text-xs font-bold uppercase tracking-widest">
                    Enlarge
                  </span>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- CTA -->
      <div class="card bg-base-200 text-center">
        <div class="card-body">
          <h2 class="text-3xl md:text-4xl font-bold text-base-content mb-6">
            Ready to upgrade your collection?
          </h2>
          <p class="text-base-content/60 mb-10 max-w-xl mx-auto">
            Download NeoStation and join the community building the future of retro gaming.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <a
              href="/downloads"
              class="btn btn-primary"
            >
              Download Now
            </a>
            <a
              href="https://discord.gg/xE2kgKsRVq"
              class="btn btn-ghost border border-base-content/20"
            >
              Join the Discord
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</PageLayout>

<!-- Image Modal -->
<div
  id="imageModal"
  class="fixed inset-0 bg-black bg-opacity-75 hidden z-50 flex items-center justify-center p-4"
>
  <div class="relative max-w-4xl max-h-full">
    <img
      id="modalImage"
      src=""
      alt="NeoStation Screenshot"
      class="rounded-xl shadow-2xl max-w-full max-h-full object-contain"
    />
    <button
      id="closeModal"
      class="absolute top-4 right-4 text-white text-3xl font-bold hover:text-base-content/70 transition-colors bg-black/20 hover:bg-black/40 w-10 h-10 flex items-center justify-center rounded-full"
    >
      &times;
    </button>
  </div>
</div>

<script>
  let currentSlide = 0;
  const slides = document.querySelectorAll("#hero-slider img");
  const totalSlides = slides.length;

  if (totalSlides > 0) {
    setInterval(() => {
      slides[currentSlide]!.classList.remove("opacity-100");
      slides[currentSlide]!.classList.add("opacity-0");
      currentSlide = (currentSlide + 1) % totalSlides;
      slides[currentSlide]!.classList.remove("opacity-0");
      slides[currentSlide]!.classList.add("opacity-100");
    }, 5000);
  }

  const modal = document.getElementById("imageModal");
  const modalImage = document.getElementById("modalImage") as HTMLImageElement;
  const closeBtn = document.getElementById("closeModal");
  const triggers = document.querySelectorAll(".modal-trigger");

  function openModal(src: string) {
    if (modal && modalImage) {
      modalImage.src = src;
      modal.classList.remove("hidden");
      document.body.style.overflow = "hidden";
    }
  }

  function closeModal() {
    if (modal) {
      modal.classList.add("hidden");
      document.body.style.overflow = "auto";
    }
  }

  triggers.forEach((trigger) => {
    trigger.addEventListener("click", () => {
      const src = trigger.getAttribute("data-image");
      if (src) openModal(src);
    });
  });

  closeBtn?.addEventListener("click", closeModal);

  modal?.addEventListener("click", (e) => {
    if (e.target === modal) closeModal();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });
</script>
