                </div>
    
              </div>
            </section>
    
          </div>
        </div>
        <p class="hint" id="legend"></p>
      </main>
    
      <!-- ============ CONTROL RAIL ============ -->
      <aside class="rail-col">
        <div class="setup-row">
          <div class="source-pick">
            <span class="fld" id="presetLbl">Start from</span>
            <div class="dd" id="presetDD">
              <button class="dd-btn" type="button" aria-haspopup="listbox" aria-expanded="false" aria-labelledby="presetLbl"><span class="dd-val">Dark</span></button>
              <ul class="dd-menu" aria-label="Starting preset"></ul>
            </div>
          </div>
          <button class="btn" id="importBtn" type="button">Import JSON</button>
          <input type="file" id="fileInput" class="file-hide" accept=".json,application/json" />
        </div>
    
        <div class="meta-row">
          <div><label for="tName">Theme name</label><input type="text" id="tName" value="My Custom Theme" /></div>
          <div><label for="tId">Palette id <span style="text-transform:none">(key used in code)</span></label><input type="text" id="tId" value="my_custom_theme" /></div>
          <div><label for="tAuthor">Author</label><input type="text" id="tAuthor" placeholder="Your name or handle" /></div>
          <fieldset class="seg" id="brightSeg" aria-label="Color scheme">
              <button type="button" data-b="dark" class="on">Dark</button>
              <button type="button" data-b="light">Light</button>
            </fieldset>
        </div>
    
        <div id="groups"></div>
        <div id="effects"></div>
    
        <div class="export-bar">
          <button class="btn" id="copyBtn" type="button">Copy JSON</button>
          <button class="btn primary" id="dlBtn" type="button">Download</button>
        </div>
      </aside>
    </div>
    
    <div class="toast" id="toast">Copied</div>
  </div>
</Base>

<script is:inline>
/* =====================================================================
   daisyUI theme model — field keys are daisyUI's exact CSS-variable
   suffixes (base-100, primary-content, …) so export drops straight into
   an `@plugin "daisyui/theme"` block. Colours are authored in oklch
   (the daisyUI convention); hex is derived only for the pickers.
   ===================================================================== */
const GROUPS = [
  { key:'base', title:'Base', n:'01', desc:'The surfaces everything sits on.',
    fields:[
      ['base-100','Base 100','App / screen background'],
      ['base-200','Base 200','Toolbars, pills, cards'],
      ['base-300','Base 300','Deeper surfaces, borders'],
      ['base-content','Base content','Default text & icons'],
    ]},
  { key:'brand', title:'Brand', n:'02', desc:'Primary actions, selection, accents.',
    fields:[
      ['primary','Primary','System-name pill, "A2600" chip'],
      ['primary-content','Primary content','Text over primary'],
      ['secondary','Secondary','Selected row / tab / filter'],
      ['secondary-content','Secondary content','Text over secondary'],
      ['accent','Accent','View Mode / Settings buttons'],
      ['accent-content','Accent content','Text over accent'],
      ['neutral','Neutral','Neutral surfaces & badges'],
      ['neutral-content','Neutral content','Text over neutral'],
    ]},
  { key:'status', title:'Status', n:'03', desc:'Semantic feedback colours.',
    fields:[
      ['info','Info','Info badges, charging'],
      ['info-content','Info content','Text over info'],
      ['success','Success','Enter / Play, battery full'],
      ['success-content','Success content','Text over success'],
      ['warning','Warning','Updates, battery medium'],
      ['warning-content','Warning content','Text over warning'],
      ['error','Error','Back button, battery low'],
      ['error-content','Error content','Text over error'],
    ]},
];
const COLOR_FIELDS = GROUPS.flatMap(g=>g.fields.map(f=>f[0]));

/* Non-colour theme variables (radius / size / border). */
const EFFECTS = [
  ['radius-selector','Radius · selector','Checkboxes, toggles, badges', ['0','0.25rem','0.5rem','1rem','2rem']],
  ['radius-field','Radius · field','Buttons, inputs, pills', ['0','0.25rem','0.5rem','1rem','2rem']],
  ['radius-box','Radius · box','Cards, tiles, artwork', ['0','0.25rem','0.5rem','1rem','2rem']],
  ['border','Border','Component border width', ['0','1px','1.5px','2px']],
];
const SIZE_DEFAULTS = { 'size-selector':'0.25rem', 'size-field':'0.25rem' };

/* Existing preview `--c-*` vars re-mapped onto the daisyUI token set,
   so the two-screen mock keeps working unchanged. */
const PREVIEW_VARS = {
  '--c-bg':'base-100','--c-surface':'base-200','--c-onSurface':'base-content',
  '--c-primary':'primary','--c-onPrimary':'primary-content',
  '--c-secondary':'secondary','--c-onSecondary':'secondary-content',
  '--c-tertiary':'accent','--c-onTertiary':'accent-content',
  '--c-success':'success','--c-onSuccess':'success-content',
  '--c-info':'info','--c-onInfo':'info-content',
  '--c-warning':'warning','--c-onWarning':'warning-content',
  '--c-error':'error','--c-onError':'error-content',
  '--c-battFull':'success','--c-outline':'base-300','--c-card':'base-200',
};

/* ---- oklch <-> sRGB hex (Björn Ottosson's OKLab matrices) ---- */
function parseOklch(str){
  const m=String(str).match(/oklch\(\s*([\d.]+)%?\s+([\d.]+)\s+([\d.-]+)/i);
  if(!m) return {L:0,C:0,H:0};
  let L=Number.parseFloat(m[1]); if(str.includes('%')) L/=100;
  return {L, C:Number.parseFloat(m[2]), H:Number.parseFloat(m[3])};
}
function oklchToHex(str){
  const {L,C,H}=parseOklch(str);
  const hr=H*Math.PI/180;
  const a=C*Math.cos(hr);
  const b=C*Math.sin(hr);
  const l_=L+0.3963377774*a+0.2158037573*b;
  const m_=L-0.1055613458*a-0.0638541728*b;
  const s_=L-0.0894841775*a-1.2914855480*b;
  const l=l_**3;
  const m=m_**3;
  const s=s_**3;
  const r= 4.0767416621*l-3.3077115913*m+0.2309699292*s;
  const g=-1.2684380046*l+2.6097574011*m-0.3413193965*s;
  const bl=-0.0041960863*l-0.7034186147*m+1.7076147010*s;
  const gam=c=>{const v=c<=0.0031308?12.92*c:1.055*c ** (1/2.4)-0.055; return Math.max(0,Math.min(1,v));};
  const h2=x=>Math.round(gam(x)*255).toString(16).padStart(2,'0');
  return `#${h2(r)}${h2(g)}${h2(bl)}`;
}
function hexToOklch(hex){
  let h=hex.replace('#',''); if(h.length===3) h=h.split('').map(c=>c+c).join('');
  const lin=c=>{const v=c/255; return v<=0.04045?v/12.92:((v+0.055)/1.055) ** 2.4;};
  const r=lin(Number.parseInt(h.slice(0,2),16));
  const g=lin(Number.parseInt(h.slice(2,4),16));
  const b=lin(Number.parseInt(h.slice(4,6),16));
  const l=Math.cbrt(0.4122214708*r+0.5363325363*g+0.0514459929*b);
  const m=Math.cbrt(0.2119034982*r+0.6806995451*g+0.1073969566*b);
  const s=Math.cbrt(0.0883024619*r+0.2817188376*g+0.6299787005*b);
  const L=0.2104542553*l+0.7936177850*m-0.0040720468*s;
  const a=1.9779984951*l-2.4285922050*m+0.4505937099*s;
  const bb=0.0259040371*l+0.7827717662*m-0.8086757660*s;
  const C=Math.sqrt(a*a+bb*bb); let Hh=Math.atan2(bb,a)*180/Math.PI; if(Hh<0)Hh+=360;
  const r3=n=>+n.toFixed(3);
  return `oklch(${+(L*100).toFixed(2)}% ${r3(C)} ${+Hh.toFixed(2)})`;
}

/* ---- Presets: colour values copied verbatim from daisyUI (oklch). ---- */
