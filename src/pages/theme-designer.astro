                  <div class="gnote n-info"><svg class="ni" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><circle cx="12" cy="12" r="9"/><path d="M12 11v5M12 7.5v.5"/></svg>Downloading metadata…</div>
                </div>
    
                <div class="gcard">
                  <span class="gh">Battery</span>
                  <div><div class="mlabel"><span>Controller 1</span><b>92%</b></div><div class="gmeter m-batt-full"><span style="width:92%"></span></div></div>
