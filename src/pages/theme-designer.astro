                  <div class="grow">Berzerk</div>
                  <div class="grow">BurgerTime</div>
                  <div class="grow">California Games</div>
                  <div class="grow">Centipede</div>
                  <div class="grow">Chopper Command</div>
                </div>
              </div>
    
              <div class="fan">
                <div class="scan"></div><div class="glow"></div>
                <div class="fan-bottom">
                  <div class="ratingrow">
                    <span class="rating"><span class="star">★</span>9.0</span>
                    <div class="ttl">
