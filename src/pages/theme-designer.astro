function newModel(){ return { name:'My Custom Theme', id:'my_custom_theme', author:'', scheme:'dark',
  colors:{}, oklch:{}, effects:{...EFX_DARK} }; }
let model = newModel();

const $=s=>document.querySelector(s);
const inputs={};
const efxInputs={};

function buildGroups(){
  const root=$('#groups'); root.innerHTML='';
  for(const g of GROUPS){
    const el=document.createElement('div'); el.className='group';
    el.innerHTML=`<h3><span class="n">${g.n}</span>${g.title}</h3><p>${g.desc}</p>`;
    for(const [field,label,desc] of g.fields){
      const row=document.createElement('div'); row.className='swatch';
      row.innerHTML=`
        <span class="pick"><input type="color" aria-label="${label} color" /></span>
        <span class="info"><span class="nm">${label}</span><span class="ds">${desc}</span></span>
        <input class="hex" type="text" spellcheck="false" maxlength="7" aria-label="${label} hex" />`;
      const color=row.querySelector('input[type=color]');
      const hex=row.querySelector('.hex');
      inputs[field]={color,hex,pick:row.querySelector('.pick')};
      color.addEventListener('input',()=>setField(field,color.value));
      hex.addEventListener('input',()=>{ if(/^#?[0-9a-fA-F]{6}$/.test(hex.value)) setField(field,`#${hex.value.replace('#','')}`); });
      hex.addEventListener('blur',()=>syncOne(field));
      el.appendChild(row);
    }
    root.appendChild(el);
  }
}
function buildEffects(){
  const root=$('#effects'); root.innerHTML='';
  const el=document.createElement('div'); el.className='group';
  el.innerHTML=`<h3><span class="n">04</span>Effects</h3><p>daisyUI radius &amp; border.</p>`;
  for(const [key,label,desc,opts] of EFFECTS){
    const row=document.createElement('div'); row.className='efx';
    if(opts==='toggle'){
      row.innerHTML=`<span class="info"><span class="nm">${label}</span><span class="ds">${desc}</span></span>
        <div class="tog" data-k="${key}"><button type="button" data-val="0">Off</button><button type="button" data-val="1">On</button></div>`;
      row.querySelector('.tog').addEventListener('click',e=>{ const v=e.target.dataset.val; if(v!=null) setEffect(key,v); });
    }else{
      const o=opts.map(v=>`<option value="${v}">${v==='0'?'0 (none)':v}</option>`).join('');
      row.innerHTML=`<span class="info"><span class="nm">${label}</span><span class="ds">${desc}</span></span><select data-k="${key}">${o}</select>`;
      row.querySelector('select').addEventListener('change',e=>setEffect(key,e.target.value));
    }
    efxInputs[key]=row; el.appendChild(row);
  }
  root.appendChild(el);
}
function syncEffects(){
  for(const [key,,,opts] of EFFECTS){
    const v=model.effects[key];
    const row=efxInputs[key]; if(!row) continue;
    if(opts==='toggle') for(const b of row.querySelectorAll('.tog button')) b.classList.toggle('on',b.dataset.val===String(v));
    else row.querySelector('select').value=v;
  }
}
function setEffect(key,val){ model.effects[key]=val; syncEffects(); applyPreview(); renderJson(); }

function setField(field,hex){ const h=hex.toUpperCase(); model.colors[field]=h; model.oklch[field]=hexToOklch(h); syncOne(field); applyPreview(); renderJson(); }
function syncOne(field){ const v=model.colors[field];
const i=inputs[field]; if(!i||!v)return; i.color.value=v; i.hex.value=v; i.pick.style.background=v; }
function syncAll(){ for(const f in inputs) syncOne(f); }

function applyPreview(){
  const s=$('#screen');
  for(const [cssVar,field] of Object.entries(PREVIEW_VARS)) s.style.setProperty(cssVar,model.colors[field]);
  // daisyUI radius tokens -> preview em scale (×3 keeps the default look); rem maps to em, px stays px
  const remEm=v=>{ const n=Number.parseFloat(v)||0; return String(v||'').includes('rem')?`${n*3}em`:(n?`${n*3}px`:'0'); };
  s.style.setProperty('--r-sel',  remEm(model.effects['radius-selector']));
  s.style.setProperty('--r-field',remEm(model.effects['radius-field']));
  s.style.setProperty('--r-box',  remEm(model.effects['radius-box']));
  s.style.setProperty('--brd', model.effects.border!=null?String(model.effects.border):'1px');
  const rail=$('#ledRail');
  for(const c of rail.querySelectorAll('.led-chip')) c.remove();
  const order=['primary','secondary','accent','neutral','base-100','base-200','base-300','base-content','info','success','warning','error'];
  for(const f of order){
    const chip=document.createElement('span'); chip.className='led-chip';
    chip.style.background=model.colors[f]; chip.style.color=model.colors[f];
    if(['primary','secondary','accent','success','error'].includes(f)) chip.setAttribute('data-glow','');
    chip.title=`${f} ${model.colors[f]}`; rail.appendChild(chip);
  }
}

/* ---- Export builder ---- */
function jsonExport(){
  const colors={}; for(const f of COLOR_FIELDS) colors[f]=model.colors[f];
  return JSON.stringify({ name:model.name, id:model.id, author:model.author, colorScheme:model.scheme, colors, effects:{...model.effects,...SIZE_DEFAULTS} }, null, 2);
}
function renderJson(){}
function currentExport(){ return jsonExport(); }

function loadModel(m){
  const src=m.colors||m;
  const isOklch=v=>/oklch/i.test(v||'');
  model=newModel();
  model.name=m.name||'Imported Theme';
  model.id=m.id||(m.name||'imported').toLowerCase().replace(/[^a-z0-9]+/g,'_');
  model.author=m.author||'';
  model.scheme=m.scheme||m.colorScheme||m.brightness||'dark';
  const base=PRESETS.dark.colors;
  for(const f of COLOR_FIELDS){
    const raw=src[f]!=null?src[f]:base[f];
    if(isOklch(raw)){ model.oklch[f]=raw; model.colors[f]=oklchToHex(raw).toUpperCase(); }
    else { model.colors[f]=String(raw).toUpperCase(); model.oklch[f]=hexToOklch(raw); }
  }
  model.effects={...EFX_DARK, ...(m.effects||{})};
  $('#tName').value=model.name; $('#tId').value=model.id; $('#tAuthor').value=model.author;
  setBright(model.scheme); syncAll(); syncEffects(); applyPreview(); renderJson();
}
function setBright(b){ model.scheme=b; for(const x of $('#brightSeg').querySelectorAll('button')) x.classList.toggle('on',x.dataset.b===b); }

let toastT;
function toast(msg){ const t=$('#toast'); t.textContent=msg; t.classList.add('show'); clearTimeout(toastT); toastT=setTimeout(()=>t.classList.remove('show'),1600); }

function setView(v){
  for(const el of document.querySelectorAll('.view')) el.classList.toggle('on',el.dataset.view===v);
  for(const b of document.querySelectorAll('.viewtog button')) b.classList.toggle('on',b.dataset.v===v);
  $('#legend').innerHTML = v==='browse'
    ? 'Screen background is <b>base-100</b>, toolbar/pills <b>base-200</b>, text <b>base-content</b> · selected tab + filter use <b>secondary</b> · system-name pill uses <b>primary</b> · View Mode / Settings use <b>accent</b> · Enter uses <b>success</b> · battery uses <b>success</b>. (A/B/X/Y glyphs are monochrome.)'
    : v==='detail'
    ? 'Selected list row uses <b>secondary</b> · "A2600" chip uses <b>primary</b> · Back uses <b>error</b> · Play uses <b>success</b> · text uses <b>base-content</b>.'
    : 'Every NeoStation UI role at a glance — buttons, toggles, notifications, battery & storage, badges and dialogs. <b>primary</b> / <b>secondary</b> / <b>accent</b> drive actions · <b>success</b> / <b>warning</b> / <b>info</b> / <b>error</b> drive status · surfaces are <b>base-100/200/300</b>, text <b>base-content</b>.';
}

function initPresetDropdown(){
  const dd=$('#presetDD');
  const btn=dd.querySelector('.dd-btn');
  const val=dd.querySelector('.dd-val');
  const menu=dd.querySelector('.dd-menu');
  let active=-1;
  const items=[];
  for(const [k,p] of Object.entries(PRESETS)){
    const li=document.createElement('li'); li.setAttribute('role','option'); li.dataset.k=k; li.textContent=p.name;
    li.setAttribute('aria-selected', k==='dark'?'true':'false');
    if(k==='dark') val.textContent=p.name;
    li.addEventListener('click',()=>select(k));
    li.addEventListener('mousemove',()=>setActive(items.indexOf(li)));
    menu.appendChild(li); items.push(li);
  }
  function setActive(i){ for(let n=0;n<items.length;n++) items[n].classList.toggle('active',n===i); active=i;
    if(items[i]) items[i].scrollIntoView({block:'nearest'}); }
  function select(k){ const p=PRESETS[k]; val.textContent=p.name;
    for(const li of items) li.setAttribute('aria-selected', li.dataset.k===k?'true':'false');
    close();
    loadModel({name:$('#tName').value,id:$('#tId').value,author:$('#tAuthor').value,scheme:p.scheme,colors:p.colors,effects:p.effects});
    toast(`${p.name} loaded`); }
  function open(){ dd.classList.add('open'); btn.setAttribute('aria-expanded','true');
    setActive(Math.max(0,items.findIndex(li=>li.getAttribute('aria-selected')==='true'))); }
  function close(){ dd.classList.remove('open'); btn.setAttribute('aria-expanded','false'); for(const li of items) li.classList.remove('active'); }
  btn.addEventListener('click',e=>{ e.stopPropagation(); dd.classList.contains('open')?close():open(); });
  btn.addEventListener('keydown',e=>{
    if(e.key==='ArrowDown'||e.key==='ArrowUp'){ e.preventDefault();
      if(!dd.classList.contains('open')){ open(); return; }
      setActive((active+(e.key==='ArrowDown'?1:-1)+items.length)%items.length); }
    else if(e.key==='Enter'||e.key===' '){ e.preventDefault();
      if(dd.classList.contains('open')&&active>=0) select(items[active].dataset.k); else open(); }
    else if(e.key==='Escape'){ close(); }
  });
  document.addEventListener('click',e=>{ if(!dd.contains(e.target)) close(); });
}

function init(){
  buildGroups(); buildEffects();
  initPresetDropdown();

  $('#tName').addEventListener('input',e=>{model.name=e.target.value;renderJson();});
  $('#tId').addEventListener('input',e=>{model.id=e.target.value.trim().replace(/\s+/g,'_');renderJson();applyPreview();});
  $('#tAuthor').addEventListener('input',e=>{model.author=e.target.value;renderJson();});
  $('#brightSeg').addEventListener('click',e=>{const b=e.target.dataset.b; if(b){setBright(b);renderJson();}});
  document.querySelector('.viewtog').addEventListener('click',e=>{const v=e.target.dataset.v; if(v)setView(v);});

  const copy=()=>navigator.clipboard.writeText(currentExport()).then(()=>toast('JSON copied'));
  $('#copyBtn').addEventListener('click',copy);
  $('#dlBtn').addEventListener('click',()=>{
    const blob=new Blob([currentExport()],{type:'application/json'});
    const a=document.createElement('a'); a.href=URL.createObjectURL(blob); a.download=`${model.id||'theme'}.json`;
    a.click(); URL.revokeObjectURL(a.href); toast('Downloaded'); });
  $('#importBtn').addEventListener('click',()=>$('#fileInput').click());
  $('#fileInput').addEventListener('change',e=>{ const f=e.target.files[0]; if(!f)return;
    const r=new FileReader(); r.onload=()=>{ try{ loadModel(JSON.parse(r.result)); toast('Imported'); }catch(_err){ toast('Invalid JSON'); } };
    r.readAsText(f); e.target.value=''; });

  loadModel({...PRESETS.dark, name:'My Custom Theme', id:'my_custom_theme'}); setView('browse');
}
init();
</script>
