                  <div><div class="mlabel"><span>Headset</span><b>11%</b></div><div class="gmeter m-batt-low"><span style="width:11%"></span></div></div>
                </div>
    
                <div class="gcard">
                  <span class="gh">Storage</span>
                  <div><div class="mlabel"><span>Internal</span><b>174 / 256 GB</b></div><div class="gmeter m-store"><span style="width:68%"></span></div></div>
                  <div><div class="mlabel"><span>SD Card</span><b>41 / 128 GB</b></div><div class="gmeter m-store"><span style="width:32%"></span></div></div>
                </div>
    
                <div class="gcard">
                  <span class="gh">Game List</span>
                  <div class="glist2">
                    <div class="gli">Adventure</div>
                    <div class="gli sel">Missile Command</div>
                    <div class="gli">Pitfall!</div>
