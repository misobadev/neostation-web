              </div>
            </section>
    
            <!-- ============ DETAIL / game view ============ -->
            <section class="view detail" data-view="detail">
              <!-- detail keeps the same nav toolbar, anchored top-right -->
              <div class="dtoolbar">
                <div class="toolcluster">
                  <span class="shoulder">LB</span>
