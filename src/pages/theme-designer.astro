                </div>
              </div>
    
              <div class="cf">
                <div class="tile side a2"><div class="art"><span class="logo">ARCADE</span></div></div>
                <div class="tile center a1"><div class="art"><span class="logo">ATARI 2600</span></div></div>
                <div class="tile side a3"><div class="art"><span class="logo">ATARI 7800</span></div></div>
              </div>
    
              <div class="filterrow">
                <span class="fpill">ALL</span><span class="fpill">ANDROID</span><span class="fpill">ARCADE</span>
