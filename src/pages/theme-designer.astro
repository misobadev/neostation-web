                  </div>
                </div>
              </div>
            </section>
    
            <!-- ============ COMPONENTS ============ -->
            <section class="view components" data-view="components">
              <div class="gallery">
    
                <div class="gcard">
                  <span class="gh">Buttons</span>
                  <div class="grow">
                    <button type="button" class="gb primary">Play</button>
                    <button type="button" class="gb secondary">Scrape</button>
                    <button type="button" class="gb accent">Sync</button>
                  </div>
                  <div class="grow">
                    <button type="button" class="gb outline">Cancel</button>
                    <button type="button" class="gb ghost">Skip</button>
                    <button type="button" class="gb dis">Disabled</button>
                  </div>
                </div>
    
                <div class="gcard">
                  <span class="gh">Toggles &amp; Radios</span>
                  <div class="grow" style="justify-content:space-between"><span class="glab">Show hidden games</span><span class="gtog on"></span></div>
                  <div class="grow" style="justify-content:space-between"><span class="glab">Box art only</span><span class="gtog"></span></div>
                  <div class="grow"><span class="grad on"></span><span class="glab">List view</span></div>
                  <div class="grow"><span class="grad"></span><span class="glab">Grid view</span></div>
                </div>
    
