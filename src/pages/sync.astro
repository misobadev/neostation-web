---
import { Icon } from "astro-icon/components";
import PageLayout from "@/layouts/Base.astro";

const meta = {
  description:
    "Connect NeoStation to your preferred sync provider. NeoSync is available now, with RomM, Syncthing, and Google Drive coming soon.",
  title: "Sync Providers - NeoStation",
};
---

<PageLayout meta={meta}>
  <div class="relative py-12 md:py-24 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 relative z-10">

      <!-- Hero -->
      <div class="text-center mb-20 md:mb-24">
        <div
          class="inline-flex items-center gap-3 px-4 py-2 bg-base-content/5 rounded-full border border-base-content/20 text-xs font-bold text-primary uppercase tracking-widest mb-6"
        >
          <Icon name="heroicons:cloud-arrow-up" class="w-4 h-4 animate-pulse" />
          Extensible Provider System
        </div>
        <h1
          class="text-5xl md:text-7xl font-black text-base-content tracking-tight leading-tight mb-8"
        >
          Sync your saves. <span class="text-primary">Your way.</span>
        </h1>
        <p class="text-xl text-base-content/60 max-w-3xl mx-auto leading-relaxed font-medium">
          NeoStation's sync system is built around pluggable providers. Connect
          to <strong class="text-base-content">NeoSync</strong> today, or choose your own
          backend when new providers become available.
        </p>
      </div>

      <!-- Providers Grid -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">

        <!-- NeoSync — Available -->
        <div class="card card-border bg-base-200">
          <div class="card-body">
            <div class="flex justify-between items-start mb-4">
              <div class="size-14 rounded-2xl bg-primary/10 flex items-center justify-center">
                <Icon name="heroicons:cloud-arrow-up" class="w-8 h-8 text-primary" />
              </div>
              <span class="badge badge-primary badge-sm">Available</span>
            </div>
            <h3 class="card-title">NeoSync</h3>
            <p class="text-sm text-base-content/60">
              Official NeoStation cloud save sync. Optimized for SRAM saves and
              RetroArch states. Free tier included, paid plans for larger
              collections.
            </p>
            <a href="/guide#neosync" class="btn btn-primary btn-block mt-4">
              <Icon name="heroicons:information-circle" class="w-4 h-4" />Setup Guide
            </a>
          </div>
        </div>

        <!-- RomM — Coming Soon -->
        <div class="card card-border bg-base-200 opacity-50">
          <div class="card-body">
            <div class="flex justify-between items-start mb-4">
              <div class="size-14 rounded-2xl bg-base-content/5 flex items-center justify-center">
                <Icon name="heroicons:play-circle" class="w-8 h-8 text-base-content/50" />
              </div>
              <span class="badge badge-ghost badge-sm">Coming Soon</span>
            </div>
            <h3 class="card-title text-base-content/60">RomM</h3>
            <p class="text-sm text-base-content/40">
              Self-hosted ROM manager with built-in save sync. Full control over
              your data on your own server.
            </p>
            <a href="https://romm.app/" target="_blank" rel="noopener noreferrer" class="btn btn-ghost btn-sm btn-block mt-4">
              romm.app <Icon name="heroicons:arrow-top-right-on-square" class="w-3 h-3" />
            </a>
          </div>
        </div>

        <!-- Syncthing — Coming Soon -->
        <div class="card card-border bg-base-200 opacity-50">
          <div class="card-body">
            <div class="flex justify-between items-start mb-4">
              <div class="size-14 rounded-2xl bg-base-content/5 flex items-center justify-center">
                <Icon name="heroicons:arrow-path" class="w-8 h-8 text-base-content/50" />
              </div>
              <span class="badge badge-ghost badge-sm">Coming Soon</span>
            </div>
            <h3 class="card-title text-base-content/60">Syncthing</h3>
            <p class="text-sm text-base-content/40">
              Open-source P2P sync with no cloud dependency. Sync directly
              between your own devices without any third-party server.
            </p>
            <div class="btn btn-ghost btn-sm btn-block mt-4 opacity-60 pointer-events-none">
              Peer-to-Peer
            </div>
          </div>
        </div>

        <!-- Google Drive — Coming Soon -->
        <div class="card card-border bg-base-200 opacity-50">
          <div class="card-body">
            <div class="flex justify-between items-start mb-4">
              <div class="size-14 rounded-2xl bg-base-content/5 flex items-center justify-center">
                <Icon
                  name="heroicons:cloud"
                  class="w-8 h-8 text-base-content/50"
                />
              </div>
              <span class="badge badge-ghost badge-sm">Coming Soon</span>
            </div>
            <h3 class="card-title text-base-content/60">Google Drive</h3>
            <p class="text-sm text-base-content/40">
              Use your existing Google Drive storage to back up and sync saves.
              No new account needed if you already use Google services.
            </p>
            <div class="btn btn-ghost btn-sm btn-block mt-4 opacity-60 pointer-events-none">
              Google Account
            </div>
          </div>
        </div>
      </div>

      <p class="text-center text-xs text-base-content/40 italic">
        More providers planned. Architecture is open, community integrations welcome via the
        <a
          href="https://github.com/misobadev/neostation-frontend"
          target="_blank"
          class="text-base-content/50 hover:text-primary transition-colors underline"
          >open source repo</a
        >.
      </p>

    </div>
  </div>
</PageLayout>
