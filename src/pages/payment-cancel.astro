---
import PageLayout from "@/layouts/Base.astro";
import { Icon } from "astro-icon/components";

const meta = {
  description:
    "Your payment was cancelled. No charges have been made to your account.",
  title: "Payment Cancelled - NeoStation",
};
---

<!-- Need to move payments to other domain because its for neosync -->
<PageLayout meta={meta}>
  <div class="max-w-lg mx-auto my-12 px-4">
    <div class="text-center mb-8">
      <div class="w-16 h-16 mx-auto mb-4 bg-error rounded-full flex items-center justify-center">
        <Icon name="heroicons:x-circle" class="w-8 h-8 text-base-content" />
      </div>
      <h1 class="text-2xl font-black text-error">Payment Cancelled</h1>
    </div>

    <div class="card bg-base-200">
      <div class="card-body items-center text-center gap-4">
        <div class="badge badge-warning badge-lg">No Worries!</div>
        <p id="cancel-message" class="text-base-content/60">Your payment has been cancelled. No charges have been made.</p>
        <div class="alert alert-info text-sm">
          <Icon name="heroicons:information-circle" class="w-5 h-5" />
          <span>You can return to the NeoStation app to try again later.</span>
        </div>
      </div>
    </div>

    <script>
      const urlParams = new URLSearchParams(window.location.search);
      const username = urlParams.get("username") || "User";
      const plan = urlParams.get("plan") || "your plan";
      const period = urlParams.get("period") || "monthly";

      const messageElement = document.getElementById("cancel-message");
      if (messageElement) {
        messageElement.textContent = `${username}, your payment for the ${plan} plan (${period}) has been cancelled. No charges have been made to your account.`;
      }
    </script>
  </div>
</PageLayout>
