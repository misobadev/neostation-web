---
import { Icon } from "astro-icon/components";

/** 
	Uses https://www.astroicon.dev/getting-started/
	Find icons via guide: https://www.astroicon.dev/guides/customization/#open-source-icon-sets
	Installed packs: @iconify-json/mdi, @iconify-json/simple-icons
*/
const socialLinks: {
  friendlyName: string;
  link: string;
  name: string;
  color: string;
}[] = [
  {
    friendlyName: "Discord",
    link: "https://discord.gg/xE2kgKsRVq",
    name: "simple-icons:discord",
    color: "bg-indigo-600 hover:bg-indigo-500",
  },
];
---

<div class="mt-12">
  <h2 class="text-xl font-semibold mb-2 text-accent text-center">
    Join the Open Source Community
  </h2>
  <p class="text-sm text-gray-500 text-center mb-6">
    The NeoStation app is open source under GPL v3. This website is MIT licensed.
  </p>
  <div class="flex flex-col items-center gap-4">
    <a
      href="https://github.com/misobadev/neostation-frontend"
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-3 px-6 py-3 bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/20 text-white font-bold rounded-xl transition-all hover:scale-105 shadow-lg"
    >
      <Icon name="simple-icons:github" class="w-5 h-5" />
      View Source on GitHub
    </a>
    <div
      class="bg-slate-800/30 backdrop-blur-sm border border-slate-700/50 rounded-2xl p-6 shadow-lg"
    >
      <div class="flex flex-wrap items-center justify-center gap-4">
        <span class="text-sm font-medium text-gray-400 mr-2">Community</span>
        <ul class="flex items-center gap-3">
          {
            socialLinks.map(({ friendlyName, link, name, color }) => (
              <li class="flex">
                <a
                  class={`group relative p-3 rounded-xl ${color} hover:scale-110 transition-all duration-300 shadow-md hover:shadow-lg`}
                  href={link}
                  rel="noreferrer"
                  target="_blank"
                  title={friendlyName}
                >
                  <Icon
                    aria-hidden="true"
                    class="h-6 w-6 text-white drop-shadow-sm"
                    focusable="false"
                    name={name}
                  />
                  <span class="sr-only">{friendlyName}</span>
                  <div class="absolute inset-0 rounded-xl bg-white/10 opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</div>
