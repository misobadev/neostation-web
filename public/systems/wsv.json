{
  "system": {
    "id": "wsv",
    "name": "Watara Supervision",
    "short_name": "WSV",
    "details": {
      "manufacturer": "Watara",
      "release_date": "1992-01-01",
      "description": "Watara's monochrome handheld with a tiltable screen.",
      "type": "handheld"
    },
    "ids": {
      "screenscraper": 107,
      "retroachievements": 63
    },
    "folders": [
      "wsv",
      "supervision",
      "Watara Supervision",
      "watara"
    ],
    "colors": [
      "#9E9E9E",
      "#616161"
    ],
    "extensions": [
      "bin",
      "sv",
      "zip",
      "7z"
    ]
  },
  "emulators": [
    {
      "name": "RetroArch64 Potator",
      "default_core": true,
      "unique_id": "wsv.ra64.potator",
      "description": "Supported extensions: bin, sv, zip, 7z",
      "is_retroachievements_compatible": true,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"potator\""
        }
      }
    },
    {
      "name": "RetroArch32 Potator",
      "default_core": true,
      "unique_id": "wsv.ra32.potator",
      "description": "Supported extensions: bin, sv, zip, 7z",
      "is_retroachievements_compatible": true,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"potator\""
        }
      }
    },
    {
      "name": "RetroArch Potator",
      "default_core": true,
      "unique_id": "wsv.ra.potator",
      "description": "Supported extensions: bin, sv, zip, 7z",
      "is_retroachievements_compatible": true,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"potator\""
        },
        "windows": {
          "executable": "retroarch.exe",
          "args": "-L potator_libretro.dll \"{file.path}\""
        },
        "linux": {
          "executable": "retroarch",
          "args": "-L potator_libretro.so \"{file.path}\""
        },
        "macos": {
          "executable": "RetroArch.App",
          "args": "-L potator_libretro.dylib \"{file.path}\""
        }
      }
    }
  ],
  "neosync": {
    "sync": true,
    "android_sync_folder": [
      "{SYNC_DIR}"
    ],
    "windows_sync_folder": [
      "{SYNC_DIR}"
    ],
    "linux_sync_folder": [
      "{SYNC_DIR}"
    ],
    "macos_sync_folder": [
      "{SYNC_DIR}"
    ]
  }
}
