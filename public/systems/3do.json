    ],
    "extensions": [
      "bin",
      "chd",
      "cue",
      "iso",
      "zip",
      "m3u"
    ]
  },
  "emulators": [
    {
      "name": "RetroArch Opera",
      "default_core": true,
      "unique_id": "3do.ra.opera",
      "is_retroachievements_compatible": true,
      "description": "Supported extensions: bin, chd, cue, iso, zip.",
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"opera\""
        },
        "windows": {
          "executable": "retroarch.exe",
          "args": "-L opera_libretro.dll \"{file.path}\""
        },
        "linux": {
          "executable": "retroarch",
          "args": "-L opera_libretro.so \"{file.path}\""
        },
        "macos": {
          "executable": "RetroArch.App",
          "args": "-L opera_libretro.dylib \"{file.path}\""
        }
      }
    },
    {
      "name": "RetroArch64 Opera",
      "default_core": true,
      "unique_id": "3do.ra64.opera",
      "is_retroachievements_compatible": true,
      "description": "Supported extensions: bin, chd, cue, iso, zip.",
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"opera\""
        }
      }
    },
    {
      "name": "RetroArch32 Opera",
      "default_core": true,
      "unique_id": "3do.ra32.opera",
      "is_retroachievements_compatible": true,
      "description": "Supported extensions: bin, chd, cue, iso, zip.",
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"opera\""
        }
      }
    }
  ],
  "neosync": {
    "sync": true,
