      "release_date": "1993-10-04",
      "description": "Panasonic's 32-bit CD-based console with advanced multimedia capabilities.",
      "type": "console"
    },
    "ids": {
      "screenscraper": 29,
      "retroachievements": 43
    },
    "folders": [
      "3do",
      "3DO Interactive Multiplayer",
      "Panasonic 3DO"
    ],
    "colors": [
      "#455a64",
