{
  "system": {
    "id": "wsc",
    "name": "WonderSwan Color",
    "short_name": "WSC",
    "details": {
      "manufacturer": "Bandai",
      "release_date": "1999-12-09",
      "description": "Color successor to the WonderSwan with a reflective TFT screen.",
      "type": "handheld"
    },
    "ids": {
      "screenscraper": 45,
      "retroachievements": 53
    },
    "folders": [
      "wsc",
      "WonderSwan Color",
      "Bandai WonderSwan Color",
      "WonderSwanColor"
    ],
    "colors": [
      "#EC407A",
      "#FFFFFF"
    ],
    "extensions": [
      "ws",
      "wsc",
      "pc2",
      "7z",
      "zip"
    ]
  },
  "emulators": [
    {
      "name": "Standalone SwanEmu",
      "unique_id": "wsc.com.explusalpha.SwanEmu",
      "description": "Supported extensions: ws, wsc, pc2, 7z, zip",
      "is_retroachievements_compatible": false,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.explusalpha.SwanEmu/com.imagine.BaseActivity   -a android.intent.action.VIEW   -d \"{file.localuri}\"    -t application/zip"
        }
      }
    },
    {
      "name": "Retroarch64 Beetle Cygne",
      "unique_id": "wsc.ra64.mednafen_wswan",
      "description": "Supported extensions: ws, wsc, pc2, 7z, zip",
      "is_retroachievements_compatible": true,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture  --es ROM \"{file.path}\"  --es LIBRETRO \"mednafen_wswan\""
        }
      }
    },
    {
      "name": "Retroarch32 Beetle Cygne",
      "unique_id": "wsc.ra32.mednafen_wswan",
      "description": "Supported extensions: ws, wsc, pc2, 7z, zip",
      "is_retroachievements_compatible": true,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture  --es ROM \"{file.path}\"  --es LIBRETRO \"mednafen_wswan\""
        }
      }
    },
    {
      "name": "Retroarch Beetle Cygne",
      "default": true,
      "unique_id": "wsc.ra.mednafen_wswan",
      "description": "Supported extensions: ws, wsc, pc2, 7z, zip",
      "is_retroachievements_compatible": true,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture  --es ROM \"{file.path}\"  --es LIBRETRO \"mednafen_wswan\""
        },
        "windows": {
          "executable": "retroarch.exe",
          "args": "-L mednafen_wswan_libretro.dll \"{file.path}\""
        },
        "linux": {
          "executable": "retroarch",
          "args": "-L mednafen_wswan_libretro.so \"{file.path}\""
        },
        "macos": {
          "executable": "RetroArch.App",
          "args": "-L mednafen_wswan_libretro.dylib \"{file.path}\""
        }
      }
    }
  ],
  "neosync": {
    "sync": true,
    "android_sync_folder": [
      "{SYNC_DIR}"
    ],
    "windows_sync_folder": [
      "{SYNC_DIR}"
    ],
    "linux_sync_folder": [
      "{SYNC_DIR}"
    ],
    "macos_sync_folder": [
      "{SYNC_DIR}"
    ]
  }
}
