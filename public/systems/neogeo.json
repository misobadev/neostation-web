      "is_retroachievements_compatible": false,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.explusalpha.NeoEmu/com.imagine.BaseActivity -d \"{file.path}\" -t application/zip --activity-clear-task --activity-clear-top --activity-no-history"
        }
      }
    },
