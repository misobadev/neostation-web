      "release_date": "2008-01-01",
      "description": "Open-source minimalist 8-bit console based on AVR microcontrollers.",
      "type": "console"
    },
    "ids": {
      "screenscraper": 216,
      "retroachievements": 80
    },
    "folders": [
      "uze",
      "Uzebox"
    ],
    "colors": [
      "#1976D2",
      "#BBDEFB"
    ],
    "extensions": [
      "uze",
      "zip",
      "7z"
    ]
  },
  "emulators": [
    {
      "name": "RetroArch64 Uzem",
      "default_core": true,
      "unique_id": "uze.ra64.uzem",
      "description": "Supported extensions: uze.",
      "is_retroachievements_compatible": true,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"uzem\""
        }
      }
    },
    {
      "name": "RetroArch32 Uzem",
      "default_core": true,
      "unique_id": "uze.ra32.uzem",
      "description": "Supported extensions: uze.",
      "is_retroachievements_compatible": true,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"uzem\""
        }
      }
    },
    {
      "name": "RetroArch Uzem",
      "default_core": true,
      "unique_id": "uze.ra.uzem",
      "description": "Supported extensions: uze.",
      "is_retroachievements_compatible": true,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"uzem\""
        },
        "windows": {
          "executable": "retroarch.exe",
          "args": "-L uzem_libretro.dll \"{file.path}\""
        },
        "linux": {
          "executable": "retroarch",
          "args": "-L uzem_libretro.so \"{file.path}\""
        },
        "macos": {
          "executable": "RetroArch.App",
          "args": "-L uzem_libretro.dylib \"{file.path}\""
        }
      }
    }
  ],
  "neosync": {
    "sync": true,
    "android_sync_folder": [
      "{SYNC_DIR}"
    ],
    "windows_sync_folder": [
      "{SYNC_DIR}"
    ],
    "linux_sync_folder": [
      "{SYNC_DIR}"
    ],
    "macos_sync_folder": [
      "{SYNC_DIR}"
    ]
  }
