      "#42A5F5"
    ],
    "extensions": [
      "cue",
      "ccd",
      "toc",
      "chd",
      "m3u"
    ]
  },
  "emulators": [
    {
      "name": "RetroArch64 Beetle PC-FX",
      "default_core": true,
      "unique_id": "pcfx.ra64.mednafen_pcfx",
      "description": "Supported extensions: cue, ccd, toc, chd.",
      "is_retroachievements_compatible": false,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"mednafen_pcfx\""
        }
      }
    },
    {
      "name": "RetroArch32 Beetle PC-FX",
      "default_core": true,
      "unique_id": "pcfx.ra32.mednafen_pcfx",
      "description": "Supported extensions: cue, ccd, toc, chd.",
      "is_retroachievements_compatible": false,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"mednafen_pcfx\""
        }
      }
    },
    {
      "name": "RetroArch Beetle PC-FX",
      "default_core": true,
      "unique_id": "pcfx.ra.mednafen_pcfx",
      "description": "Supported extensions: cue, ccd, toc, chd.",
      "is_retroachievements_compatible": false,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"mednafen_pcfx\""
        },
        "windows": {
          "executable": "retroarch.exe",
          "args": "-L mednafen_pcfx_libretro.dll \"{file.path}\""
        },
        "linux": {
          "executable": "retroarch",
          "args": "-L mednafen_pcfx_libretro.so \"{file.path}\""
        },
        "macos": {
          "executable": "RetroArch.App",
          "args": "-L mednafen_pcfx_libretro.dylib \"{file.path}\""
        }
      }
    }
  ],
  "neosync": {
