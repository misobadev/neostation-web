    ]
  },
  "emulators": [
    {
      "name": "Standalone LynxEmu",
      "unique_id": "lynx.com.explusalpha.LynxEmu",
      "description": "Supported extensions: lnx, o, zip, 7z.",
      "is_retroachievements_compatible": false,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.explusalpha.LynxEmu/com.imagine.BaseActivity -a android.intent.action.VIEW -d \"{file.localuri}\" -t application/zip --activity-clear-task --activity-clear-top --activity-no-history"
        }
      }
    },
    {
      "name": "RetroArch64 Beetle Lynx",
      "unique_id": "lynx.ra64.mednafen_lynx",
      "description": "Supported extensions: lnx, o, zip, 7z.",
      "is_retroachievements_compatible": true,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"mednafen_lynx\""
        }
