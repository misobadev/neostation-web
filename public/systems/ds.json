  "emulators": [
    {
      "name": "RetroArch MelonDS",
      "default": true,
      "unique_id": "ds.ra.melonds",
      "is_retroachievements_compatible": true,
      "description": "MelonDS core for RetroArch.",
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"melonds\""
        },
        "windows": {
          "executable": "retroarch.exe",
          "args": "-L melonds_libretro.dll \"{file.path}\""
        },
        "linux": {
          "executable": "retroarch",
          "args": "-L melonds_libretro.so \"{file.path}\""
        },
        "macos": {
          "executable": "RetroArch.App",
          "args": "-L melonds_libretro.dylib \"{file.path}\""
        }
      }
    },
    {
