  },
  "emulators": [
    {
      "name": "RetroArch64 FreeChaF",
      "default_core": true,
      "unique_id": "chf.ra64.freechaf",
      "description": "Supported extensions: chf, bin, zip.",
      "is_retroachievements_compatible": true,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"freechaf\""
        }
      }
    },
    {
      "name": "RetroArch32 FreeChaF",
      "default_core": true,
      "unique_id": "chf.ra32.freechaf",
      "description": "Supported extensions: chf, bin, zip.",
      "is_retroachievements_compatible": true,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"freechaf\""
        }
      }
    },
    {
      "name": "RetroArch FreeChaF",
      "default_core": true,
      "unique_id": "chf.ra.freechaf",
      "description": "Supported extensions: chf, bin, zip.",
      "is_retroachievements_compatible": true,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"freechaf\""
        },
        "windows": {
          "executable": "retroarch.exe",
          "args": "-L freechaf_libretro.dll \"{file.path}\""
        },
        "linux": {
          "executable": "retroarch",
          "args": "-L freechaf_libretro.so \"{file.path}\""
        },
        "macos": {
          "executable": "RetroArch.App",
          "args": "-L freechaf_libretro.dylib \"{file.path}\""
        }
      }
    }
  ],
