          "launch_arguments": "-n com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"pokemini\""
        },
        "windows": {
          "executable": "retroarch.exe",
          "args": "-L pokemini_libretro.dll \"{file.path}\""
