        },
        "windows": {
          "executable": "cemu.exe",
          "args": "-g \"{file.path}\" -f"
        },
        "linux": {
          "executable": "cemu",
          "args": "-g \"{file.path}\" -f"
        },
        "macos": {
          "executable": "Cemu.app",
          "args": "-g \"{file.path}\" -f"
        }
      }
    }
