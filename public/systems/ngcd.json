{
  "system": {
    "id": "ngcd",
    "name": "Neo Geo CD",
    "short_name": "NGCD",
    "details": {
      "manufacturer": "SNK",
      "release_date": "1994-09-09",
      "description": "SNK's CD-based Neo Geo console with cheaper media and Red Book audio.",
      "type": "console"
    },
    "ids": {
      "screenscraper": 70,
      "retroachievements": 56
    },
    "folders": [
      "ngcd",
      "neogeocd",
      "Neo Geo CD"
    ],
    "colors": [
      "#E0E0E0",
      "#9E9E9E"
    ],
    "extensions": [
      "chd",
      "cue"
    ]
  },
  "emulators": [
    {
      "name": "RetroArch64 NeoCD",
      "unique_id": "ngcd.ra64.neocd",
      "description": "Supported extensions: chd, cue.",
      "is_retroachievements_compatible": true,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"neocd\""
        }
      }
    },
    {
      "name": "RetroArch32 NeoCD",
      "unique_id": "ngcd.ra32.neocd",
      "description": "Supported extensions: chd, cue.",
      "is_retroachievements_compatible": true,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"neocd\""
        }
      }
    },
    {
      "name": "RetroArch NeoCD",
      "default": true,
      "unique_id": "ngcd.ra.neocd",
      "description": "Supported extensions: chd, cue.",
      "is_retroachievements_compatible": true,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"neocd\""
        },
        "windows": {
          "executable": "retroarch.exe",
          "args": "-L neocd_libretro.dll \"{file.path}\""
        },
        "linux": {
          "executable": "retroarch",
          "args": "-L neocd_libretro.so \"{file.path}\""
        },
        "macos": {
          "executable": "retroarch",
          "args": "-L neocd_libretro.dylib \"{file.path}\""
        }
      }
    },
    {
      "name": "RetroArch FBNeo",
      "unique_id": "ngcd.ra.fbneo",
      "description": "Supported extensions: 7z, ccd, cue, zip.",
      "is_retroachievements_compatible": false,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"fbneo\""
        },
        "windows": {
          "executable": "retroarch.exe",
          "args": "-L fbneo_libretro.dll \"{file.path}\""
        },
        "linux": {
          "executable": "retroarch",
          "args": "-L fbneo_libretro.so \"{file.path}\""
        },
        "macos": {
          "executable": "RetroArch.App",
          "args": "-L fbneo_libretro.dylib \"{file.path}\""
        }
      }
    },
    {
      "name": "RetroArch64 FBNeo",
      "unique_id": "ngcd.ra64.fbneo",
      "description": "Supported extensions: 7z, ccd, cue, zip.",
      "is_retroachievements_compatible": false,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"fbneo\""
        }
      }
    },
    {
      "name": "RetroArch32 FBNeo",
      "unique_id": "ngcd.ra32.fbneo",
      "description": "Supported extensions: 7z, ccd, cue, zip.",
      "is_retroachievements_compatible": false,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"fbneo\""
        }
      }
    }
  ],
  "neosync": {
    "sync": true,
