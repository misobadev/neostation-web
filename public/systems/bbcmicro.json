  "emulators": [
    {
      "name": "RetroArch64 b2",
      "unique_id": "bbcmicro.ra64.b2",
      "description": "Supported extensions: ssd, dsd.",
      "is_retroachievements_compatible": false,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture  --es ROM \"{file.path}\"  --es LIBRETRO \"b2\""
        }
      }
    },
    {
      "name": "RetroArch32 b2",
      "unique_id": "bbcmicro.ra32.b2",
      "description": "Supported extensions: ssd, dsd.",
      "is_retroachievements_compatible": false,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture  --es ROM \"{file.path}\"  --es LIBRETRO \"b2\""
        }
      }
    },
    {
      "name": "RetroArch b2",
      "default": true,
      "unique_id": "bbcmicro.ra.b2",
      "description": "Supported extensions: ssd, dsd.",
      "is_retroachievements_compatible": false,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture  --es ROM \"{file.path}\"  --es LIBRETRO \"b2\""
        },
        "windows": {
          "executable": "retroarch.exe",
          "args": "-L b2_libretro.dll \"{file.path}\""
        },
        "linux": {
          "executable": "retroarch",
          "args": "-L b2_libretro.so \"{file.path}\""
        },
        "macos": {
          "executable": "RetroArch.App",
          "args": "-L b2_libretro.dylib \"{file.path}\""
        }
      }
    }
  ],
