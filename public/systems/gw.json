        "android": {
          "launch_arguments": "-n com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture  --es ROM \"{file.path}\"  --es LIBRETRO \"gw\""
        }
      }
    },
    {
      "name": "RetroArch GW",
      "default": true,
      "unique_id": "gw.ra.gw",
      "description": "Supported extensions: mgw.",
      "is_retroachievements_compatible": false,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture  --es ROM \"{file.path}\"  --es LIBRETRO \"gw\""
        },
        "windows": {
          "executable": "retroarch.exe",
          "args": "-L gw_libretro.dll \"{file.path}\""
        },
        "linux": {
          "executable": "retroarch",
          "args": "-L gw_libretro.so \"{file.path}\""
        },
        "macos": {
          "executable": "RetroArch.App",
          "args": "-L gw_libretro.dylib \"{file.path}\""
        }
      }
    },
    {
      "name": "RetroArch MAME/MESS",
      "unique_id": "gw.ra.mamemess",
      "description": "Supported extensions: zip",
      "is_retroachievements_compatible": false,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture  --es ROM \"{file.path}\"  --es LIBRETRO \"mamemess\""
        },
        "windows": {
          "executable": "retroarch.exe",
          "args": "-L mamemess_libretro.dll \"{file.path}\""
        },
        "linux": {
          "executable": "retroarch",
          "args": "-L mamemess_libretro.so \"{file.path}\""
        },
        "macos": {
          "executable": "RetroArch.App",
          "args": "-L mamemess_libretro.dylib \"{file.path}\""
        }
      }
    }
