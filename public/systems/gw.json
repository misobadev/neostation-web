    ],
    "colors": [
      "#BDBDBD",
      "#757575"
    ],
    "extensions": [
      "mgw",
      "zip",
      "7z"
    ]
  },
  "emulators": [
    {
      "name": "RetroArch64 GW",
      "unique_id": "gw.ra64.gw",
      "description": "Supported extensions: mgw.",
      "is_retroachievements_compatible": false,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture  --es ROM \"{file.path}\"  --es LIBRETRO \"gw\""
        }
      }
    },
    {
      "name": "RetroArch64 MAME/MESS",
      "unique_id": "gw.ra64.mamemess",
      "description": "Supported extensions: zip.",
      "is_retroachievements_compatible": false,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture  --es ROM \"{file.path}\"  --es LIBRETRO \"mamemess\""
        }
      }
    },
    {
      "name": "RetroArch32 GW",
      "unique_id": "gw.ra32.gw",
