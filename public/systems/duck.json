{
  "system": {
    "id": "duck",
    "name": "Mega Duck",
    "short_name": "Duck",
    "details": {
      "manufacturer": "Welback",
      "release_date": "1993-01-01",
      "description": "Welback's 8-bit monochrome handheld console, also known as Cougar Boy.",
      "type": "handheld"
    },
    "ids": {
      "screenscraper": 90,
      "retroachievements": 69
    },
    "folders": [
      "megaduck",
      "Mega Duck"
    ],
    "colors": [
      "#FFF176",
      "#424242"
    ],
    "extensions": [
      "bin",
      "zip",
      "7z"
    ]
  },
  "emulators": [
    {
      "name": "RetroArch64 SameDuck",
      "default_core": true,
      "unique_id": "duck.ra64.sameduck",
      "description": "Supported extensions: bin.",
      "is_retroachievements_compatible": true,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"sameduck\""
        }
      }
    },
    {
      "name": "RetroArch32 SameDuck",
      "default_core": true,
      "unique_id": "duck.ra32.sameduck",
      "description": "Supported extensions: bin.",
      "is_retroachievements_compatible": true,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"sameduck\""
        }
      }
    },
    {
      "name": "RetroArch SameDuck",
      "default_core": true,
      "unique_id": "duck.ra.sameduck",
      "description": "Supported extensions: bin.",
      "is_retroachievements_compatible": true,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"sameduck\""
        },
        "windows": {
          "executable": "retroarch.exe",
          "args": "-L sameduck_libretro.dll \"{file.path}\""
        },
        "linux": {
          "executable": "retroarch",
          "args": "-L sameduck_libretro.so \"{file.path}\""
        },
        "macos": {
          "executable": "RetroArch.App",
          "args": "-L sameduck_libretro.dylib \"{file.path}\""
        }
      }
    }
  ],
  "neosync": {
    "sync": true,
    "android_sync_folder": [
      "{SYNC_DIR}"
    ],
    "windows_sync_folder": [
      "{SYNC_DIR}"
    ],
    "linux_sync_folder": [
      "{SYNC_DIR}"
    ],
    "macos_sync_folder": [
      "{SYNC_DIR}"
    ]
  }
}
