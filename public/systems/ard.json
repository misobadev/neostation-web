  "emulators": [
    {
      "name": "RetroArch Arduous",
      "unique_id": "ard.ra.arduous",
      "description": "Supported extensions: hex.",
      "is_retroachievements_compatible": true,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"arduous\""
        },
        "windows": {
          "executable": "retroarch.exe",
          "args": "-L arduous_libretro.dll \"{file.path}\""
        },
        "linux": {
          "executable": "retroarch",
          "args": "-L arduous_libretro.so \"{file.path}\""
        },
