{
  "system": {
    "id": "naomigd",
    "name": "Sega Naomi GD-ROM",
    "short_name": "Naomi GD",
    "details": {
      "manufacturer": "Sega",
      "release_date": "2001-02-01",
      "description": "Sega's GD-ROM based arcade variant of the NAOMI hardware.",
      "type": "arcade"
    },
    "ids": {
      "screenscraper": 227,
      "retroachievements": 27
    },
    "folders": [
      "naomigd",
      "Sega Naomi GD-ROM"
    ],
    "colors": [
      "#78909C",
      "#CFD8DC"
    ],
    "extensions": [
      "zip",
      "7z",
      "lst",
      "dat",
      "chd"
    ]
  },
  "emulators": [
    {
      "name": "Standalone Flycast",
      "unique_id": "naomigd.com.flycast.emulator",
      "description": "Supported extensions: 7z, chd, dat, lst, zip.",
      "is_retroachievements_compatible": true,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.flycast.emulator/com.flycast.emulator.MainActivity -a android.intent.action.VIEW -d \"{file.uri}\"",
          "keep_saf_uri": true
        }
      }
    },
    {
      "name": "RetroArch64 Flycast",
      "default_core": true,
      "unique_id": "naomigd.ra64.flycast",
      "description": "Supported extensions: 7z, chd, dat, lst, zip.",
      "is_retroachievements_compatible": true,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"flycast\""
        }
      }
    },
    {
      "name": "RetroArch32 Flycast",
      "default_core": true,
      "unique_id": "naomigd.ra32.flycast",
      "description": "Supported extensions: 7z, chd, dat, lst, zip.",
      "is_retroachievements_compatible": true,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"flycast\""
        }
      }
    },
    {
      "name": "RetroArch Flycast",
      "default_core": true,
      "unique_id": "naomigd.ra.flycast",
      "description": "Supported extensions: cdi, gdi, chd, cue, bin, elf, zip, 7z, lst, dat, m3u, zip.",
      "is_retroachievements_compatible": true,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"flycast\""
        },
        "windows": {
          "executable": "retroarch.exe",
          "args": "-L flycast_libretro.dll \"{file.path}\""
        },
        "linux": {
          "executable": "retroarch",
          "args": "-L flycast_libretro.so \"{file.path}\""
        },
        "macos": {
          "executable": "RetroArch.App",
          "args": "-L flycast_libretro.dylib \"{file.path}\""
        }
      }
    }
  ],
  "neosync": {
    "sync": true,
    "android_sync_folder": [
      "{SYNC_DIR}"
    ],
    "windows_sync_folder": [
      "{SYNC_DIR}"
    ],
    "linux_sync_folder": [
      "{SYNC_DIR}"
    ],
    "macos_sync_folder": [
      "{SYNC_DIR}"
    ]
  }
}
