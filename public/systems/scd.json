      "name": "Standalone Md.emu",
      "unique_id": "scd.com.explusalpha.MdEmu",
      "description": "Support extensions: 32x, 68k, bin, bms, chd, cue, gen, gg, iso, m3u, md, mdx, pco, sg, sgd, smd, sms.",
      "is_retroachievements_compatible": false,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.explusalpha.MdEmu/com.imagine.BaseActivity -a android.intent.action.VIEW -d \"{file.localuri}\""
        }
      }
    },
    {
      "name": "RetroArch64 Genesis Plus GX",
      "unique_id": "scd.ra64.genesis_plus_gx",
