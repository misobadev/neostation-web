{
  "system": {
    "id": "dc",
    "name": "Sega Dreamcast",
    "short_name": "DC",
    "details": {
      "manufacturer": "Sega",
      "release_date": "1998-11-27",
      "description": "Sega's innovative 128-bit console, first with built-in online gaming.",
      "type": "console"
    },
    "ids": {
      "screenscraper": 23,
      "retroachievements": 40
    },
    "folders": [
      "dc",
      "dreamcast",
      "Sega Dreamcast"
    ],
    "colors": [
      "#F5F5F5",
      "#FFAB91"
    ],
    "extensions": [
      "cdi",
      "gdi",
      "chd",
      "cue",
      "bin",
      "elf",
      "zip",
      "7z",
      "lst",
      "m3u"
    ]
  },
  "emulators": [
    {
      "name": "Standalone Redream",
      "unique_id": "dc.io.recompiled.redream",
      "description": "Supported extensions: 7z, bin, cdi, chd, cue, elf, gdi, lst, m3u, zip.",
      "is_retroachievements_compatible": false,
      "platforms": {
        "android": {
          "launch_arguments": "-n io.recompiled.redream/.MainActivity -a android.intent.action.VIEW -d \"{file.uri}\""
        }
      }
    },
    {
      "name": "Standalone Reicast",
      "unique_id": "dc.com.reicast.emulator",
      "description": "Supported extensions: 7z, bin, cdi, chd, cue, elf, gdi, lst, zip.",
      "is_retroachievements_compatible": false,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.reicast.emulator/.MainActivity -a android.intent.action.VIEW -d \"{file.uri}\""
        }
      }
    },
    {
      "name": "Standalone Flycast",
      "unique_id": "dc.com.flycast.emulator",
      "description": "Supported extensions: 7z, bin, cdi, chd, cue, elf, gdi, lst, zip.",
      "is_retroachievements_compatible": true,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.flycast.emulator/com.flycast.emulator.MainActivity -a android.intent.action.VIEW -d \"{file.uri}\""
        }
      }
    },
    {
      "name": "RetroArch64 Flycast",
      "unique_id": "dc.ra64.flycast",
      "description": "Supported extensions: cdi, gdi, chd, cue, bin, elf, zip, 7z, lst, m3u, zip.",
      "is_retroachievements_compatible": true,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"flycast\""
        }
      }
    },
    {
      "name": "RetroArch32 Flycast",
      "unique_id": "dc.ra32.flycast",
      "description": "Supported extensions: cdi, gdi, chd, cue, bin, elf, zip, 7z, lst, m3u, zip.",
      "is_retroachievements_compatible": true,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"flycast\""
        }
      }
    },
    {
      "name": "RetroArch Flycast",
      "default": true,
      "unique_id": "dc.ra.flycast",
      "description": "Supported extensions: cdi, gdi, chd, cue, bin, elf, zip, 7z, lst, m3u, zip.",
      "is_retroachievements_compatible": true,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"flycast\""
        },
        "windows": {
          "executable": "retroarch.exe",
          "args": "-L flycast_libretro.dll \"{file.path}\""
        },
        "linux": {
          "executable": "retroarch",
          "args": "-L flycast_libretro.so \"{file.path}\""
        },
        "macos": {
          "executable": "RetroArch.App",
          "args": "-L flycast_libretro.dylib \"{file.path}\""
        }
      }
    }
  ],
  "neosync": {
    "sync": true,
    "android_sync_folder": [
      "{SYNC_DIR}"
    ],
    "windows_sync_folder": [
      "{SYNC_DIR}",
      "{FLYCAST_SAVES}"
    ],
    "linux_sync_folder": [
      "{SYNC_DIR}"
    ],
    "macos_sync_folder": [
      "{SYNC_DIR}"
    ]
  }
}
