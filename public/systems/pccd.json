    "extensions": [
      "ccd",
      "chd",
      "cue",
      "m3u",
      "pce",
      "sgx",
      "toc",
      "zip",
      "7z"
    ]
  },
  "emulators": [
    {
      "name": "Standalone PCE.emu",
      "unique_id": "pccd.com.PceEmu",
      "description": "Support extensions: ccd, chd, cue, m3u, pce, sgx, toc.",
      "is_retroachievements_compatible": false,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.PceEmu/com.imagine.BaseActivity -a android.intent.action.VIEW -d \"{file.uri}\" -t application/zip --activity-clear-task --activity-clear-top --activity-no-history"
        }
      }
    },
    {
      "name": "RetroArch64 Beetle PCE Fast",
      "unique_id": "pccd.ra64.mednafen_pce_fast",
      "description": "Supported extensions: ccd, chd, cue, m3u, pce, toc.",
      "is_retroachievements_compatible": true,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"mednafen_pce_fast\""
        }
      }
    },
    {
      "name": "RetroArch64 Beetle PCE",
      "unique_id": "pccd.ra64.mednafen_pce",
      "description": "Supported extensions: ccd, chd, cue, m3u, pce, sgx, toc, zip, 7z.",
      "is_retroachievements_compatible": false,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"mednafen_pce\""
        }
