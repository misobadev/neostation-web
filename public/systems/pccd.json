    {
      "name": "RetroArch Beetle PCE Fast",
      "unique_id": "pccd.ra.mednafen_pce_fast",
      "description": "Supported extensions: ccd, chd, cue, m3u, pce, toc.",
      "is_retroachievements_compatible": true,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"mednafen_pce_fast\""
        },
        "windows": {
          "executable": "retroarch.exe",
          "args": "-L mednafen_pce_fast_libretro.dll \"{file.path}\""
        },
        "linux": {
