{
  "system": {
    "id": "pccd",
    "name": "PC Engine-CD",
    "short_name": "PCCD",
    "details": {
      "manufacturer": "NEC",
      "release_date": "1988-12-04",
      "description": "CD-ROM add-on for the PC Engine with enhanced audio and video.",
      "type": "console"
    },
    "ids": {
      "screenscraper": 114,
      "retroachievements": 76
    },
    "folders": [
      "pccd",
      "PCEngine CD",
      "NEC PC Engine CD",
      "PCECD",
      "pcenginecd"
    ],
    "colors": [
