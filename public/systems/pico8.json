  "emulators": [
    {
      "name": "PICO-8 Android",
      "unique_id": "pico8.io.wip.pico8",
      "description": "Supported extensions: p8, png.",
      "is_retroachievements_compatible": false,
      "platforms": {
        "android": {
          "launch_arguments": "-n io.wip.pico8/com.godot.game.GodotAppLauncher -d \"{file.uri}\""
        }
      }
    },
    {
      "name": "Infinity P8 Player",
      "unique_id": "pico8.me.dt2dev.infinity",
      "description": "Supported extensions: p8, png.",
      "is_retroachievements_compatible": false,
      "platforms": {
        "android": {
          "launch_arguments": "-n me.dt2dev.infinity/me.dt2dev.infinity.SchemeActivity  -a android.intent.action.VIEW  -d \"{file.uri}\""
        }
      }
    },
    {
      "name": "RetroArch64 Fake08",
      "unique_id": "pico8.ra64.fake08",
      "description": "Supported extensions: p8, png.",
      "is_retroachievements_compatible": false,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture  --es ROM \"{file.path}\"  --es LIBRETRO \"fake08\""
        }
      }
    },
