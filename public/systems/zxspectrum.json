          "launch_arguments": "-n com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture  --es ROM \"{file.path}\"  --es LIBRETRO \"fuse\""
        },
        "windows": {
          "executable": "retroarch.exe",
