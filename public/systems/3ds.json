      "description": "Supported extensions: 3ds, 3dsx, app, axf, cci, cxi, elf.",
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\" --es LIBRETRO \"citra\""
        },
        "windows": {
          "executable": "retroarch.exe",
          "args": "-L citra_libretro.dll \"{file.path}\""
        },
        "linux": {
          "executable": "retroarch",
          "args": "-L citra_libretro.so \"{file.path}\""
