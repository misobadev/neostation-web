      "Philips CD-i"
    ],
    "colors": [
      "#B0BEC5",
      "#1976D2"
    ],
    "extensions": [
      "cue",
      "chd",
      "iso"
    ]
  },
  "emulators": [
    {
      "name": "Retroarch 64 same_cdi",
      "unique_id": "cdi.ra64.same_cdi",
      "description": "Supported extensions: cue, chd, iso",
      "is_retroachievements_compatible": false,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\"  --es LIBRETRO \"same_cdi\""
        }
      }
    },
    {
      "name": "Retroarch32 same_cdi",
      "unique_id": "cdi.ra32.same_cdi",
      "description": "Supported extensions: cue, chd, iso",
      "is_retroachievements_compatible": false,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\"  --es LIBRETRO \"same_cdi\""
        }
      }
    },
    {
      "name": "Retroarch same_cdi",
      "unique_id": "cdi.ra.same_cdi",
      "description": "Supported extensions: cue, chd, iso",
      "is_retroachievements_compatible": false,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture --es ROM \"{file.path}\"  --es LIBRETRO \"same_cdi\""
        },
        "windows": {
          "executable": "retroarch.exe",
          "args": "-L same_cdi_libretro.dll \"{file.path}\""
        },
        "linux": {
          "executable": "retroarch",
          "args": "-L same_cdi_libretro.so \"{file.path}\""
        },
        "macos": {
          "executable": "RetroArch.App",
          "args": "-L same_cdi_libretro.dylib \"{file.path}\""
        }
      }
    }
  ],
  "neosync": {
    "sync": true,
    "android_sync_folder": [
      "{SYNC_DIR}"
    ],
    "windows_sync_folder": [
      "{SYNC_DIR}"
    ],
    "linux_sync_folder": [
      "{SYNC_DIR}"
    ],
    "macos_sync_folder": [
      "{SYNC_DIR}"
    ]
  }
