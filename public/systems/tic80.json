      "name": "RetroArch64 TIC80",
      "unique_id": "tic80.ra64.tic80",
      "description": "Supported extensions: tic.",
      "is_retroachievements_compatible": false,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture  --es ROM \"{file.path}\"  --es LIBRETRO \"tic80\""
        }
      }
    },
    {
