      "unique_id": "tic80.ra32.tic80",
      "description": "Supported extensions: tic.",
      "is_retroachievements_compatible": false,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture  --es ROM \"{file.path}\"  --es LIBRETRO \"tic80\""
        }
      }
    },
    {
      "name": "RetroArch TIC80",
      "unique_id": "tic80.ra.tic80",
      "description": "Supported extensions: tic.",
      "is_retroachievements_compatible": false,
      "platforms": {
        "android": {
          "launch_arguments": "-n com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture  --es ROM \"{file.path}\"  --es LIBRETRO \"tic80\""
        },
        "windows": {
          "executable": "retroarch.exe",
          "args": "-L tic80_libretro.dll \"{file.path}\""
        },
        "linux": {
          "executable": "retroarch",
          "args": "-L tic80_libretro.so \"{file.path}\""
        },
        "macos": {
          "executable": "RetroArch.App",
          "args": "-L tic80_libretro.dylib \"{file.path}\""
        }
      }
    }
  ],
