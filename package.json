{
	"name": "neostation-web",
	"type": "module",
	"version": "0.9.1",
	"private": false,
	"scripts": {
		"dev": "astro dev --host",
		"start": "astro dev",
		"build": "astro build",
		"postbuild": "pagefind --site dist",
		"preview": "astro preview",
		"clean": "rm -rf dist .astro node_modules/.vite",
		"rebuild": "npm run clean && npm run build",
		"lint": "biome lint .",
		"format": "npm run format:code && npm run format:imports",
		"format:code": "biome format . --write && prettier -w \"**/*\" \"!**/*.{md,mdx}\" --ignore-unknown --cache",
		"format:imports": "biome check --formatter-enabled=false --write",
		"check": "astro check"
	},
	"dependencies": {
		"@astrojs/markdown-remark": "^7.2.0",
		"@astrojs/markdown-satteri": "^0.3.0",
		"@astrojs/mdx": "^6.0.3",
		"@astrojs/rss": "^4.0.18",
		"@astrojs/sitemap": "^3.7.3",
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"@fontsource-variable/sora": "^5.2.8",
		"@iconify-json/heroicons": "^1.2.3",
		"@iconify-json/mdi": "^1.2.3",
		"@iconify-json/simple-icons": "^1.2.85",
		"@tailwindcss/vite": "^4.3.1",
		"astro": "^6.4.8",
		"astro-expressive-code": "^0.42.0",
		"astro-icon": "^1.1.5",
		"astro-robots-txt": "^1.0.0",
		"astro-webmanifest": "^1.0.0",
		"cssnano": "^8.0.1",
		"hastscript": "^9.0.0",
		"mdast-util-directive": "^3.0.0",
		"mdast-util-to-markdown": "^2.1.2",
		"mdast-util-to-string": "^4.0.0",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-external-links": "^3.0.0",
		"rehype-unwrap-images": "^1.0.0",
		"remark-directive": "^4.0.0",
		"satori": "^0.26.0",
		"satori-html": "^0.3.2",
		"sharp": "^0.34.2",
		"unified": "^11.0.5",
		"unist-util-visit": "^5.0.0"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.8",
		"@biomejs/biome": "^2.4.16",
		"@pagefind/default-ui": "^1.3.0",
		"@resvg/resvg-js": "^2.6.2",
		"@tailwindcss/typography": "^0.5.16",
		"@types/hast": "^3.0.4",
		"@types/mdast": "^4.0.4",
		"autoprefixer": "^10.4.21",
		"pagefind": "^1.3.0",
		"prettier": "^3.6.2",
		"prettier-plugin-astro": "0.14.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"reading-time": "^1.5.0",
		"tailwindcss": "^4.3.2",
		"typescript": "^6.0.3"
	},
	"overrides": {
		"yaml": "^2.8.3",
		"sharp": "^0.34.2",
		"vite": "^7",
		"esbuild": "^0.28.1"
	},
	"pnpm": {
		"overrides": {
			"sharp": "^0.34.2",
			"esbuild": "^0.28.1"
		},
		"onlyBuiltDependencies": [
			"@biomejs/biome",
			"@tailwindcss/oxide",
			"esbuild",
			"sharp"
		]
	}
}
